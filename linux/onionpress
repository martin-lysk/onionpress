start_containers() {
    log "Starting OnionPress containers..."

    cd "$DOCKER_DIR"

    # Handle pending key import
    if [ -f "$DATA_DIR/.import-key-pending" ]; then
        log "Pending key import detected -- removing old arti-state volume..."
        docker volume rm onionpress-arti-state >> "$LOG_FILE" 2>&1 || true
        if docker volume ls --format '{{.Name}}' 2>/dev/null | grep -q '^onionpress-arti-state$'; then
            log "Volume still in use -- force-removing containers using it..."
            docker rm -f $(docker ps -aq --filter volume=onionpress-arti-state) >> "$LOG_FILE" 2>&1 || true
            docker volume rm onionpress-arti-state >> "$LOG_FILE" 2>&1 || true
            if docker volume ls --format '{{.Name}}' 2>/dev/null | grep -q '^onionpress-arti-state$'; then
                log "ERROR: Could not remove old arti-state volume"
            fi
        fi
        docker volume rm onionpress-tor-keys >> "$LOG_FILE" 2>&1 || true
        rm -f "$DATA_DIR/.import-key-pending"
    fi

    # Set up onion address key
    FIRST_RUN=false
    if ! docker volume ls | grep -q "onionpress-arti-state"; then
        FIRST_RUN=true
        log "First run detected"
    fi

    # Read address prefix from config
    ADDRESS_PREFIX="op2"
    if [ -f "$DATA_DIR/config" ]; then
        CUSTOM_PREFIX=$(grep "^ADDRESS_PREFIX=" "$DATA_DIR/config" | cut -d= -f2)
        if [ -z "$CUSTOM_PREFIX" ]; then
            CUSTOM_PREFIX=$(grep "^VANITY_PREFIX=" "$DATA_DIR/config" | cut -d= -f2)
        fi
        if [ ! -z "$CUSTOM_PREFIX" ]; then
            ADDRESS_PREFIX="$CUSTOM_PREFIX"
        fi
    fi

    # Check for pre-existing imported key
    VANITY_DIR=""
    if [ -d "$DATA_DIR/shared/vanity-keys" ]; then
        VANITY_DIR=$(find "$DATA_DIR/shared/vanity-keys" -maxdepth 1 -type d -name "*.onion" | head -1)
        if [ -n "$VANITY_DIR" ]; then
            log "Using pre-imported key: $(basename "$VANITY_DIR")"
        fi
    fi

    if [ -n "$VANITY_DIR" ]; then
        # Always sync imported key to arti-state volume (ensures key survives restarts)
        docker volume create onionpress-arti-state >> "$LOG_FILE" 2>&1 || true
        if ! docker run --rm \
            -v onionpress-arti-state:/dest \
            --mount type=bind,source="$VANITY_DIR",target=/src \
            alpine sh -c 'mkdir -p /dest/state/keystore/hss/wordpress && cp /src/ks_hs_id.ed25519_expanded_private /dest/state/keystore/hss/wordpress/ && chown -R 100:100 /dest/state && chmod 700 /dest/state /dest/state/keystore /dest/state/keystore/hss /dest/state/keystore/hss/wordpress && chmod 600 /dest/state/keystore/hss/wordpress/*' >> "$LOG_FILE" 2>&1; then
            log "ERROR: Failed to copy address key to arti-state volume"
            return 1
        fi

        log "Address key installed to arti-state volume"
        log "Onion address: $(cat "$VANITY_DIR/hostname" 2>/dev/null || basename "$VANITY_DIR")"
    elif $FIRST_RUN; then
        log "No imported key found -- using random onion address"
    fi

    # Update images if enabled
    update_images

    # Pull pre-built images
    log "Pulling pre-built images..."
    docker compose pull >> "$LOG_FILE" 2>&1 || log "WARNING: Failed to pull images (will use cached)"

    # Start WordPress, DB, and tor-client first
    local max_attempts=3
    local attempt=1
    while [ $attempt -le $max_attempts ]; do
        if docker compose up -d wordpress db tor-client >> "$LOG_FILE" 2>&1; then
            break
        fi
        log "WARNING: docker compose up failed (attempt $attempt/$max_attempts)"
        if [ $attempt -eq $max_attempts ]; then
            log "ERROR: docker compose up failed after $max_attempts attempts"
            return 1
        fi
        attempt=$((attempt + 1))
        sleep 5
    done
    log "WordPress, DB, and Tor client containers starting"

    # Wait for WordPress HTTP
    local wp_wait=0
    while [ $wp_wait -lt 60 ]; do
        if curl -s --max-time 3 "http://localhost:${ONIONPRESS_WP_PORT}" >/dev/null 2>&1; then
            break
        fi
        sleep 2
        wp_wait=$((wp_wait + 2))
    done

    # Check if WordPress is set up (retry up to 30s — DB can be slow on cold start)
    local wp_installed=false
    local wp_check=0
    while [ $wp_check -lt 15 ]; do
        if wp_is_installed; then
            wp_installed=true
            break
        fi
        sleep 2
        wp_check=$((wp_check + 1))
    done

    if $wp_installed; then
        log "WordPress is installed -- starting Tor"
        docker compose up -d tor >> "$LOG_FILE" 2>&1 || log "ERROR: Failed to start tor container"
    else
        if [ -t 0 ]; then
            # Interactive terminal — prompt for credentials
            log "WordPress not yet installed -- running first-time setup"
            setup_wordpress_interactive
            # Now that WP is installed, start Tor
            docker compose up -d tor >> "$LOG_FILE" 2>&1 || log "ERROR: Failed to start tor container"
        else
            # Non-interactive (systemd) — wait for user to run setup
            log "WordPress not yet installed -- run 'onionpress setup' or visit http://$(hostname -I 2>/dev/null | awk '{print $1}' || echo localhost):${ONIONPRESS_WP_PORT}"
        fi
    fi

    # Start OnionHeaven server container (every node is an OH server).
    # Takeover containers and hub mode (10 intro points) are automatic via farm monitor.
    log "Starting OnionHeaven server container..."
    docker compose --profile onionheaven up -d >> "$LOG_FILE" 2>&1 || log "WARNING: Failed to start OnionHeaven container"
    # Start farm monitor for on-demand takeover containers (0 initial workers)
    start_onionheaven_farm

    # Install plugins and mu-plugins
    install_ia_plugin
    configure_ia_plugin
    install_wp_statistics
    configure_wp_statistics
    install_multisite_domain_map
    ensure_multisite
    fix_onionpress_permissions
}

stop_containers() {
    log "Stopping OnionPress containers..."
    stop_onionheaven_farm
    cd "$DOCKER_DIR"
    docker compose down 2>&1 | tee -a "$LOG_FILE"
    log "Containers stopped"
}

# ─── Status queries ──────────────────────────────────────────────────

get_status() {
    cd "$DOCKER_DIR"
    docker compose ps --format json 2>/dev/null | jq -s '.' 2>/dev/null || echo "[]"
}

get_onion_address() {
    cd "$DOCKER_DIR"
    ONION_ADDR=$(docker compose exec -T tor cat /var/lib/tor/hidden_service/wordpress/hostname 2>/dev/null || echo "")
    if [ ! -z "$ONION_ADDR" ]; then
        echo "$ONION_ADDR"
        return 0
    fi
    echo "Generating..."
    return 1
}

wait_for_services() {
    cd "$DOCKER_DIR"
    local max_wait=120
    local waited=0
    local wp_ready=false
    local onion_ready=false
    local onion_addr=""

    log "Waiting for services to be ready..."

    while [ $waited -lt $max_wait ]; do
        # Get onion address
        if [ -z "$onion_addr" ] || [ "$onion_addr" = "Generating..." ]; then
            onion_addr=$(docker compose exec -T tor cat /var/lib/tor/hidden_service/wordpress/hostname 2>/dev/null || echo "")
        fi

        # Check WordPress
        if [ "$wp_ready" = false ]; then
            if curl -s --max-time 3 "http://localhost:${ONIONPRESS_WP_PORT}" >/dev/null 2>&1; then
                log "WordPress is responding on localhost:${ONIONPRESS_WP_PORT}"
                wp_ready=true

                if ! wp_is_installed; then
                    log "WordPress not installed -- setup required, skipping Tor wait"
                    return 0
                fi
            fi
        fi

        # Check Tor bootstrap
        if [ "$onion_ready" = false ] && [ ! -z "$onion_addr" ] && [ "$onion_addr" != "Generating..." ]; then
            if docker compose logs --tail 100 tor 2>/dev/null | grep -q -E "Bootstrapped 100% \(done\)|Sufficiently bootstrapped"; then
                if docker compose exec -T tor wget -q -O /dev/null --timeout=5 http://wordpress:80/ 2>/dev/null; then
                    log "Onion service ready: ${onion_addr}"
                    onion_ready=true
                fi
            fi
        fi

        # Both ready
        if [ "$wp_ready" = true ] && [ "$onion_ready" = true ]; then
            log "All services are ready after ${waited}s"
            ONION_ADDR="$onion_addr"

            # Write onion address to shared volume for WordPress plugins
            docker exec onionpress-tor cp /var/lib/tor/hidden_service/wordpress/hostname /var/lib/onionpress/onion_address 2>>"$LOG_FILE" && \
                log "Onion address written to shared volume" || \
                log "WARNING: Failed to write onion address to shared volume"

            return 0
        fi

        sleep 2
        waited=$((waited + 2))
    done

    log "WARNING: Services not fully ready after ${max_wait}s (wp=${wp_ready}, onion=${onion_ready})"
    if [ ! -z "$onion_addr" ] && [ "$onion_addr" != "Generating..." ]; then
        ONION_ADDR="$onion_addr"
    else
        ONION_ADDR="Generating..."
    fi
    # Return success — containers are running, Tor may still be bootstrapping.
    # Failing here would cause systemd to kill the running containers.
    return 0
}

# ─── Backup & Restore ─────────────────────────────────────────────────

create_backup() {
    # Creates a password-protected zip with Tor keys, database, wp-content, and metadata.
    # Usage: create_backup <password> <output_path>
    local password="$1"
    local output_path="$2"
    local staging

    if [ -z "$password" ]; then
        echo "ERROR: Password is required" >&2
        return 1
    fi

    staging=$(mktemp -d -t onionpress-backup-XXXXXX)
    trap "rm -rf '$staging'" RETURN

    # 1. Extract Tor keys from vanity-keys directory
    log "Backup: extracting Tor keys..."
    mkdir -p "$staging/tor-keys"
    local key_file
    key_file=$(find "$DATA_DIR/shared/vanity-keys" -name "ks_hs_id.ed25519_expanded_private" 2>/dev/null | head -1)
    if [ -z "$key_file" ]; then
        # Try extracting from the arti-state volume
        key_file=$(docker run --rm -v onionpress-arti-state:/src alpine cat /src/state/keystore/hss/wordpress/ks_hs_id.ed25519_expanded_private 2>/dev/null) || true
        if [ -n "$key_file" ]; then
            echo "$key_file" > "$staging/tor-keys/ks_hs_id.ed25519_expanded_private"
        else
            log "WARNING: No Tor key found — backup will not include keys"
        fi
    else
        cp "$key_file" "$staging/tor-keys/"
    fi

    # 2. Dump WordPress database
    log "Backup: exporting database..."
    mkdir -p "$staging/database"
    local db_pass="${WORDPRESS_DB_PASSWORD:-}"
    if [ -z "$db_pass" ]; then
        setup_db_passwords
        db_pass="$WORDPRESS_DB_PASSWORD"
    fi
    docker exec onionpress-db mariadb-dump -u wordpress "-p${db_pass}" wordpress > "$staging/database/wordpress.sql" 2>>"$LOG_FILE"
    if [ $? -ne 0 ] || [ ! -s "$staging/database/wordpress.sql" ]; then
        log "ERROR: Database export failed"
        return 1
    fi

    # 3. Copy wp-content from container
    log "Backup: copying wp-content (themes, plugins, uploads)..."
    docker cp onionpress-wordpress:/var/www/html/wp-content/. "$staging/wp-content" 2>>"$LOG_FILE"

    # 4. Get onion address and write metadata
    local onion_addr
    onion_addr=$(docker exec onionpress-tor cat /var/lib/tor/hidden_service/wordpress/hostname 2>/dev/null | tr -d '\n\r ' || echo "")

    log "Backup: writing metadata..."
    python3 -c "
import json, sys
metadata = {
    'onion_address': sys.argv[1],
    'backup_date': sys.argv[2],
    'onionpress_version': sys.argv[3],
    'platform': 'linux'
}
with open(sys.argv[4], 'w') as f:
    json.dump(metadata, f, indent=2)
" "$onion_addr" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$ONIONPRESS_VERSION" "$staging/metadata.json"

    # 5. Create password-protected zip
    log "Backup: creating encrypted zip archive..."
    rm -f "$output_path"
    (cd "$staging" && zip -r -P "$password" "$output_path" .) >>"$LOG_FILE" 2>&1
    if [ $? -ne 0 ]; then
        log "ERROR: zip failed"
        return 1
    fi

    local size
    size=$(du -h "$output_path" | cut -f1)
    log "Backup: complete ($size) -> $output_path"
}

restore_backup() {
    # Restores from a password-protected backup zip.
    # Usage: restore_backup <password> <zip_path>
    local password="$1"
    local zip_path="$2"
    local staging

    if [ -z "$password" ] || [ -z "$zip_path" ]; then
        echo "ERROR: Password and zip path are required" >&2
        return 1
    fi
    if [ ! -f "$zip_path" ]; then
        echo "ERROR: Backup file not found: $zip_path" >&2
        return 1
    fi

    staging=$(mktemp -d -t onionpress-restore-XXXXXX)
    trap "rm -rf '$staging'" RETURN

    # Extract zip
    log "Restore: extracting backup archive..."
    if ! unzip -P "$password" -o "$zip_path" -d "$staging" >>"$LOG_FILE" 2>&1; then
        log "ERROR: Failed to extract backup (wrong password or corrupt zip)"
        return 1
    fi

    # Verify metadata exists
    local metadata_file="$staging/metadata.json"
    if [ ! -f "$metadata_file" ]; then
        metadata_file="$staging/./metadata.json"
    fi
    if [ ! -f "$metadata_file" ]; then
        log "ERROR: Not a valid OnionPress backup (no metadata.json)"
        return 1
    fi

    local onion_address
    onion_address=$(python3 -c "import json; print(json.load(open('$metadata_file')).get('onion_address',''))" 2>/dev/null || echo "")
    log "Restore: backup from $onion_address"

    # 1. Restore Tor keys
    local key_file="$staging/tor-keys/ks_hs_id.ed25519_expanded_private"
    if [ -f "$key_file" ] && [ -n "$onion_address" ]; then
        log "Restore: writing Tor keys..."
        # Mark arti-state volume for removal on next start (can't remove now — containers may be running)
        touch "$DATA_DIR/.import-key-pending"
        rm -rf "$DATA_DIR/shared/vanity-keys/"

        # Write key to vanity-keys directory
        local addr_dir="$DATA_DIR/shared/vanity-keys/$onion_address"
        mkdir -p "$addr_dir"
        cp "$key_file" "$addr_dir/"
        echo "$onion_address" > "$addr_dir/hostname"

        # Update ADDRESS_PREFIX in config to match restored address
        local addr_base="${onion_address%.onion}"
        if [ -f "$DATA_DIR/config" ]; then
            local old_prefix
            old_prefix=$(grep "^ADDRESS_PREFIX=" "$DATA_DIR/config" 2>/dev/null | cut -d= -f2 || echo "")
            if [ -n "$old_prefix" ]; then
                local prefix_len=${#old_prefix}
                local new_prefix="${addr_base:0:$prefix_len}"
                sed -i "s/^ADDRESS_PREFIX=.*/ADDRESS_PREFIX=$new_prefix/" "$DATA_DIR/config"
                log "Restore: updated ADDRESS_PREFIX to $new_prefix"
            fi
        fi
        log "Restore: Tor keys written for $onion_address"
    else
        log "WARNING: No Tor keys in backup — skipping key restore"
    fi

    # 2. Restore database
    local sql_file="$staging/database/wordpress.sql"
    if [ -f "$sql_file" ]; then
        log "Restore: importing database..."
        local db_pass="${WORDPRESS_DB_PASSWORD:-}"
        if [ -z "$db_pass" ]; then
            setup_db_passwords
            db_pass="$WORDPRESS_DB_PASSWORD"
        fi
        docker cp "$sql_file" onionpress-db:/tmp/wordpress.sql 2>>"$LOG_FILE"
        docker exec onionpress-db mariadb -u wordpress "-p${db_pass}" wordpress -e "source /tmp/wordpress.sql" 2>>"$LOG_FILE"
        if [ $? -ne 0 ]; then
            log "ERROR: Database import failed"
            return 1
        fi
        docker exec onionpress-db rm -f /tmp/wordpress.sql 2>/dev/null
        log "Restore: database imported"
    else
        log "WARNING: No database dump in backup — skipping"
    fi

    # 3. Restore wp-content
    local wpcontent_dir="$staging/wp-content"
    if [ -d "$wpcontent_dir" ]; then
        log "Restore: copying wp-content (themes, plugins, uploads)..."
        docker cp "$wpcontent_dir/." onionpress-wordpress:/var/www/html/wp-content/ 2>>"$LOG_FILE"
        docker exec onionpress-wordpress chown -R www-data:www-data /var/www/html/wp-content/ 2>>"$LOG_FILE"
        log "Restore: wp-content restored"
    else
        log "WARNING: No wp-content in backup — skipping"
    fi

    log "Restore: complete (from $onion_address)"
    echo "$onion_address"
}

# ─── Write status (on-demand) ────────────────────────────────────────

write_status() {
    # Apply any pending config changes from the WordPress settings page
    if [ -z "${_IN_WRITE_STATUS:-}" ]; then
        _IN_WRITE_STATUS=1 apply_config_updates 2>/dev/null || true
    fi

    cd "$DOCKER_DIR"

    # Get container states
    local containers_json
    containers_json=$(docker compose ps --format json 2>/dev/null | python3 -c "
import sys, json
containers = {}
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        c = json.loads(line)
        name = c.get('Name', c.get('name', ''))
        state = c.get('State', c.get('state', 'unknown'))
        containers[name] = state
    except json.JSONDecodeError:
        pass
print(json.dumps(containers))
" 2>/dev/null || echo '{}')

    # Get onion address
    local onion_addr
    onion_addr=$(docker compose exec -T tor cat /var/lib/tor/hidden_service/wordpress/hostname 2>/dev/null || echo "")
    onion_addr=$(echo "$onion_addr" | tr -d '\n\r ')

    # Get bootstrap percentage (use docker logs directly — compose logs needs env vars
    # and tail 50 may miss the bootstrap message in verbose Arti debug logs)
    local bootstrap_pct=0
    if docker logs onionpress-tor 2>&1 | grep -q -E "Bootstrapped 100%|Sufficiently bootstrapped"; then
        bootstrap_pct=100
    else
        local pct_line
        pct_line=$(docker logs --tail 200 onionpress-tor 2>&1 | grep -oE "Bootstrapped [0-9]+%" | tail -1 || echo "")
        if [ -n "$pct_line" ]; then
            bootstrap_pct=$(echo "$pct_line" | grep -oE "[0-9]+" || echo 0)
        fi
    fi

    # Determine overall state
    local state="unknown"
    local tor_state
    tor_state=$(echo "$containers_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('onionpress-tor','stopped'))" 2>/dev/null || echo "stopped")
    local wp_state
    wp_state=$(echo "$containers_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('onionpress-wordpress','stopped'))" 2>/dev/null || echo "stopped")

    if [ "$tor_state" = "running" ] && [ "$wp_state" = "running" ] && [ "$bootstrap_pct" = "100" ]; then
        # Verify onion service is actually reachable via Tor network
        if [ -n "$onion_addr" ] && [ "$onion_addr" != "Generating..." ]; then
            local reach_code
            reach_code=$(docker exec onionpress-tor-client curl -s --socks5-hostname 127.0.0.1:9050 --max-time 10 -o /dev/null -w "%{http_code}" "http://${onion_addr}/" 2>/dev/null || echo "000")
            if [ "$reach_code" = "200" ] || [ "$reach_code" = "301" ] || [ "$reach_code" = "302" ]; then
                state="running"
            else
                state="starting"
            fi
        else
            state="starting"
        fi
    elif [ "$wp_state" = "running" ] || [ "$tor_state" = "running" ]; then
        state="starting"
    else
        state="stopped"
    fi

    # Log state transitions — especially when the onion address first becomes reachable
    local prev_state=""
    local state_file="$DATA_DIR/.last_status_state"
    if [ -f "$state_file" ]; then
        prev_state=$(cat "$state_file" 2>/dev/null || echo "")
    fi
    if [ "$state" != "$prev_state" ]; then
        if [ "$state" = "running" ]; then
            log "Onion service is now reachable at http://${onion_addr}/"
        elif [ "$state" = "starting" ] && [ "$prev_state" = "running" ]; then
            log "Onion service is no longer reachable (state: starting)"
        elif [ "$state" = "stopped" ] && [ "$prev_state" != "" ] && [ "$prev_state" != "stopped" ]; then
            log "OnionPress stopped"
        fi
        echo "$state" > "$state_file"
    fi

    # Get uptime (seconds since tor container started)
    local uptime_seconds=0
    local started_at
    started_at=$(docker inspect --format '{{.State.StartedAt}}' onionpress-tor 2>/dev/null || echo "")
    if [ -n "$started_at" ] && [ "$started_at" != "0001-01-01T00:00:00Z" ]; then
        local started_epoch
        started_epoch=$(date -d "$started_at" +%s 2>/dev/null || echo 0)
        local now_epoch
        now_epoch=$(date +%s)
        if [ "$started_epoch" -gt 0 ] 2>/dev/null; then
            uptime_seconds=$((now_epoch - started_epoch))
        fi
    fi

    # Get wayback queue count
    local wayback_queue=0
    wayback_queue=$(docker exec onionpress-wordpress wp option get onionpress_wayback_queue --allow-root 2>/dev/null | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    print(len(data) if isinstance(data, list) else 0)
except:
    print(0)
" 2>/dev/null || echo 0)

    local now_iso
    now_iso=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Gather OnionHeaven stats
    local oh_server_active="false"
    local oh_registered_count=0
    local oh_online_count=0
    local oh_taken_over_count=0
    local oh_takeover_containers=0
    local oh_client_registered="false"
    local oh_client_hub=""
    local oh_config_enabled="false"

    # Read client registration state
    if [ -f "$DATA_DIR/onionheaven-registration.json" ]; then
        oh_client_registered=$(python3 -c "
import json, sys
try:
    with open(sys.argv[1]) as f:
        d = json.load(f)
    print('true' if d.get('registered') else 'false')
except: print('false')
" "$DATA_DIR/onionheaven-registration.json" 2>/dev/null || echo "false")
    fi

    # Read config
    if [ -f "$DATA_DIR/config" ]; then
        oh_config_enabled=$(grep "^REGISTER_WITH_ONIONHEAVEN=" "$DATA_DIR/config" 2>/dev/null | cut -d= -f2)
        oh_client_hub=$(grep "^ONIONHEAVEN_ADDRESS=" "$DATA_DIR/config" 2>/dev/null | cut -d= -f2)
    fi
    oh_config_enabled=${oh_config_enabled:-yes}
    oh_client_hub=${oh_client_hub:-oheavenfhbohpdjijmxo3xgvvuo6eleyhhorbompoycle6x5eajlp7qd.onion}

    # Check if this node is an OH server
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -q '^onionheaven$'; then
        oh_server_active="true"
        # Query OH server stats from registry DB
        local oh_stats
        oh_stats=$(docker exec onionheaven sqlite3 /var/lib/onionpress/onionheaven/registry.db \
            "SELECT
                COUNT(*) AS total,
                SUM(CASE WHEN status='online' THEN 1 ELSE 0 END) AS online,
                SUM(CASE WHEN status='taken-over' THEN 1 ELSE 0 END) AS taken_over
            FROM registry" 2>/dev/null || echo "0|0|0")
        oh_registered_count=$(echo "$oh_stats" | cut -d'|' -f1)
        oh_online_count=$(echo "$oh_stats" | cut -d'|' -f2)
        oh_taken_over_count=$(echo "$oh_stats" | cut -d'|' -f3)
        oh_registered_count=${oh_registered_count:-0}
        oh_online_count=${oh_online_count:-0}
        oh_taken_over_count=${oh_taken_over_count:-0}
        oh_takeover_containers=$(docker ps --format '{{.Names}}' 2>/dev/null | grep -cE '^onionheaven-takeover-[0-9]+$' 2>/dev/null || true)
        oh_takeover_containers=${oh_takeover_containers:-0}
    fi

    # System load averages and host uptime (Linux)
    local load_avg_json="[]"
    if [ -f /proc/loadavg ]; then
        load_avg_json=$(awk '{printf "[%s, %s, %s]", $1, $2, $3}' /proc/loadavg 2>/dev/null || echo "[]")
    fi
    local host_uptime_seconds=0
    if [ -f /proc/uptime ]; then
        host_uptime_seconds=$(awk '{printf "%d", $1}' /proc/uptime 2>/dev/null || echo 0)
    fi

    # Build status.json
    local status_json
    status_json=$(python3 -c "
import json, sys
status = {
    'state': sys.argv[1],
    'version': sys.argv[2],
    'onion_address': sys.argv[3],
    'uptime_seconds': int(sys.argv[4]),
    'bootstrap_pct': int(sys.argv[5]),
    'containers': json.loads(sys.argv[6]),
    'wayback_queue_count': int(sys.argv[7]),
    'updated_at': sys.argv[8],
    'platform': 'linux',
    'load_avg': json.loads(sys.argv[17]),
    'host_uptime_seconds': int(sys.argv[18]),
    'onionheaven': {
        'server_active': sys.argv[9] == 'true',
        'registered_count': int(sys.argv[10]),
        'online_count': int(sys.argv[11]),
        'taken_over_count': int(sys.argv[12]),
        'takeover_containers': int(sys.argv[13]),
        'client_registered': sys.argv[14] == 'true',
        'client_hub': sys.argv[15],
        'client_enabled': sys.argv[16] == 'yes',
    }
}
print(json.dumps(status, indent=2))
" "$state" "$ONIONPRESS_VERSION" "$onion_addr" "$uptime_seconds" "$bootstrap_pct" "$containers_json" "$wayback_queue" "$now_iso" \
  "$oh_server_active" "$oh_registered_count" "$oh_online_count" "$oh_taken_over_count" "$oh_takeover_containers" \
  "$oh_client_registered" "$oh_client_hub" "$oh_config_enabled" \
  "$load_avg_json" "$host_uptime_seconds")

    # Write to shared volume
    echo "$status_json" | docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/status.json' 2>>"$LOG_FILE"

    # Write version file for the settings page update checker
    echo "$ONIONPRESS_VERSION" | docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/version' 2>>"$LOG_FILE"

    # Build config-current.json from ~/.onionpress/config
    local config_json="{}"
    if [ -f "$DATA_DIR/config" ]; then
        config_json=$(python3 -c "
import json, sys
config = {}
with open(sys.argv[1]) as f:
    for line in f:
        line = line.strip()
        if not line or line.startswith('#'):
            continue
        if '=' in line:
            key, val = line.split('=', 1)
            config[key] = val
print(json.dumps(config, indent=2))
" "$DATA_DIR/config")
    fi

    echo "$config_json" | docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/config-current.json' 2>>"$LOG_FILE"

    # Write recent logs to shared volume
    if [ -f "$LOG_FILE" ]; then
        tail -100 "$LOG_FILE" | docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/recent-logs.txt' 2>/dev/null
    fi
}

# ─── Config watcher (on-demand) ──────────────────────────────────────

apply_config_updates() {
    # Check if settings page wrote config-updates.json
    local updates
    updates=$(docker exec onionpress-wordpress cat /var/lib/onionpress/config-updates.json 2>/dev/null || echo "")

    if [ -z "$updates" ] || [ "$updates" = "{}" ]; then
        return 0
    fi

    log "Applying config updates from settings page..."

    # Parse and apply each setting
    python3 -c "
import json, sys

updates = json.loads(sys.argv[1])
config_path = sys.argv[2]

# Read current config
config = {}
try:
    with open(config_path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith('#'):
                continue
            if '=' in line:
                key, val = line.split('=', 1)
                config[key] = val
except FileNotFoundError:
    pass

# Apply updates
config.update(updates)

# Write back
with open(config_path, 'w') as f:
    for key, val in config.items():
        f.write(f'{key}={val}\n')

# Print keys that changed for the shell script
for key in updates:
    print(key)
" "$updates" "$DATA_DIR/config" 2>>"$LOG_FILE"

    # Clear the updates file
    docker exec onionpress-wordpress sh -c 'rm -f /var/lib/onionpress/config-updates.json' 2>>"$LOG_FILE"

    # Handle START_ON_BOOT changes
    if echo "$updates" | python3 -c "import json,sys; d=json.loads(sys.stdin.read()); sys.exit(0 if 'START_ON_BOOT' in d else 1)" 2>/dev/null; then
        local boot_val
        boot_val=$(grep "^START_ON_BOOT=" "$DATA_DIR/config" | cut -d= -f2)
        if [ "$boot_val" = "yes" ]; then
            systemctl enable onionpress 2>>"$LOG_FILE" && log "Enabled start on boot" || log "WARNING: Failed to enable start on boot"
        else
            systemctl disable onionpress 2>>"$LOG_FILE" && log "Disabled start on boot" || log "WARNING: Failed to disable start on boot"
        fi
    fi

    # Write updated status
    write_status

    log "Config updates applied"
}

# ─── Main ─────────────────────────────────────────────────────────────

main() {
    case "${1:-start}" in
        start)
            # PID lock
            if [ -f "$PIDFILE" ]; then
                old_pid=$(cat "$PIDFILE" 2>/dev/null)
                if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
                    echo "OnionPress is already running (PID $old_pid)." >&2
                    exit 1
                fi
                rm -f "$PIDFILE"
            fi
            echo $$ > "$PIDFILE"
            trap 'rm -f "$PIDFILE"' EXIT INT TERM HUP

            # Check Docker is available
            if ! command_exists docker || ! docker info >/dev/null 2>&1; then
                log "ERROR: Docker is not available. Install Docker first."
                exit 1
            fi

            setup_db_passwords
            start_containers
            wait_for_services

            # Write initial status
            write_status

            log "OnionPress is running!"
            log "Onion address: $ONION_ADDR"
            log "Local access: http://$(hostname -I 2>/dev/null | awk '{print $1}' || echo localhost):${ONIONPRESS_WP_PORT}"

            echo ""
            echo "OnionPress is running!"
            echo "  Onion address: $ONION_ADDR"
            echo "  Local access:  http://$(hostname -I 2>/dev/null | awk '{print $1}' || echo localhost):${ONIONPRESS_WP_PORT}"
            echo "  Status page:   http://$(hostname -I 2>/dev/null | awk '{print $1}' || echo localhost):${ONIONPRESS_WP_PORT}/onionpress-status"
            echo "  Logs:          $LOG_FILE"
            ;;

        stop)
            setup_db_passwords
            stop_containers
            ;;

        restart)
            setup_db_passwords
            stop_containers
            start_containers
            wait_for_services
            write_status
            ;;

        status)
            get_status
            ;;

        address)
            get_onion_address
            ;;

        setup)
            # Usage: onionpress setup [--user USER] [--pass PASS] [--email EMAIL] [--title TITLE]
            setup_db_passwords
            cd "$DOCKER_DIR"
            if wp_is_installed; then
                echo "WordPress is already installed."
                exit 0
            fi
            # Make sure containers are running
            if ! curl -s --max-time 3 "http://localhost:${ONIONPRESS_WP_PORT}" >/dev/null 2>&1; then
                echo "WordPress container is not running. Start OnionPress first: sudo systemctl start onionpress"
                exit 1
            fi
            shift  # remove "setup" from args
            setup_wordpress_interactive "$@"
            # Start Tor if not running
            if ! docker compose ps tor --format json 2>/dev/null | grep -q running; then
                echo "  Starting Tor..."
                docker compose up -d tor >> "$LOG_FILE" 2>&1
            fi
            write_status
            echo ""
            echo "  Setup complete! Your site is now running."
            echo "  Admin panel: http://$(hostname -I 2>/dev/null | awk '{print $1}' || echo localhost):${ONIONPRESS_WP_PORT}/wp-admin"
            echo "  Status page: http://$(hostname -I 2>/dev/null | awk '{print $1}' || echo localhost):${ONIONPRESS_WP_PORT}/onionpress-status"
            ;;

        import-key)
            import_key "$2"
            ;;

        logs)
            cd "$DOCKER_DIR"
            docker compose logs -f
            ;;

        backup)
            setup_db_passwords
            local backup_pass="${2:-}"
            local backup_path="${3:-}"
            if [ -z "$backup_pass" ]; then
                echo "Usage: $0 backup <password> [output_path]"
                echo "Creates a password-protected backup of your OnionPress site."
                exit 1
            fi
            if [ -z "$backup_path" ]; then
                local onion_addr_short
                onion_addr_short=$(docker exec onionpress-tor cat /var/lib/tor/hidden_service/wordpress/hostname 2>/dev/null | tr -d '\n\r ' | sed 's/\.onion//' | cut -c1-8 || echo "unknown")
                backup_path="$DATA_DIR/OnionPress-${onion_addr_short}-$(date +%Y-%m-%d-%H-%M).zip"
            fi
            create_backup "$backup_pass" "$backup_path"
            echo "Backup saved to: $backup_path"
            ;;

        restore)
            setup_db_passwords
            local restore_pass="${2:-}"
            local restore_path="${3:-}"
            if [ -z "$restore_pass" ] || [ -z "$restore_path" ]; then
                echo "Usage: $0 restore <password> <backup_file.zip>"
                echo "Restores from an OnionPress backup. Containers must be running."
                exit 1
            fi
            echo "WARNING: This will overwrite your current database, wp-content, and Tor keys."
            echo "Press Enter to continue or Ctrl+C to cancel..."
            read -r
            restore_backup "$restore_pass" "$restore_path"
            echo "Restore complete. Restarting OnionPress..."
            stop_containers
            start_containers
            wait_for_services
            write_status
            echo "Done! OnionPress restarted with restored data."
            ;;

        update)
            log "Checking for OnionPress updates..."
            echo "  Checking for updates..."

            # Find the git repo
            local repo_dir=""
            for d in /home/*/tmp/onionpress /home/*/onionpress /opt/onionpress-src; do
                if [ -d "$d/.git" ]; then
                    repo_dir="$d"
                    break
                fi
            done

            # Clone fresh if no repo found
            if [ -z "$repo_dir" ]; then
                repo_dir="/opt/onionpress-src"
                log "No git repo found — cloning to $repo_dir..."
                echo "  Cloning OnionPress repo..."
                if ! sudo git clone https://github.com/brewsterkahle/onionpress.git "$repo_dir" >> "$LOG_FILE" 2>&1; then
                    log "ERROR: git clone failed"
                    echo "  ERROR: git clone failed. Check $LOG_FILE for details."
                    exit 1
                fi
            fi

            # Pull latest
            log "Pulling latest from $repo_dir..."
            cd "$repo_dir"
            if ! git pull --ff-only >> "$LOG_FILE" 2>&1; then
                # ff-only failed — try reset to origin/main
                log "Fast-forward pull failed, resetting to origin/main..."
                git fetch origin >> "$LOG_FILE" 2>&1
                git reset --hard origin/main >> "$LOG_FILE" 2>&1 || {
                    log "ERROR: git pull failed"
                    echo "  ERROR: git pull failed. Check $LOG_FILE for details."
                    exit 1
                }
            fi

            local new_version
            if [ -f "$repo_dir/VERSION" ]; then
                new_version=$(cat "$repo_dir/VERSION" | tr -d '[:space:]')
            else
                new_version=$(git -C "$repo_dir" describe --tags --abbrev=0 2>/dev/null || echo "unknown")
                new_version="${new_version#v}"
            fi

            # Re-install files
            log "Installing updated files..."
            local resources_dir="$repo_dir/OnionPress.app/Contents/Resources"
            sudo cp "$repo_dir/linux/onionpress" "$INSTALL_DIR/onionpress"
            sudo chmod +x "$INSTALL_DIR/onionpress"
            sudo cp -r "$resources_dir/docker" "$INSTALL_DIR/docker"
            sudo cp -r "$resources_dir/plugins" "$INSTALL_DIR/plugins"
            if [ -d "$resources_dir/scripts" ]; then
                sudo cp -r "$resources_dir/scripts" "$INSTALL_DIR/scripts"
            fi
            # Copy OnionHeaven client scripts
            sudo mkdir -p "$INSTALL_DIR/scripts"
            sudo cp "$repo_dir/src/onion_auth.py" "$INSTALL_DIR/scripts/"
            sudo cp "$repo_dir/src/key_manager.py" "$INSTALL_DIR/scripts/"
            sudo cp "$repo_dir/linux/onionheaven-client.py" "$INSTALL_DIR/scripts/"
            # Fix docker-compose port bindings for LAN access
            sudo sed -i 's/127\.0\.0\.1:\${ONIONPRESS_WP_PORT/0.0.0.0:${ONIONPRESS_WP_PORT/' "$INSTALL_DIR/docker/docker-compose.yml"
            sudo sed -i 's/127\.0\.0\.1:\${ONIONPRESS_SOCKS_PORT/0.0.0.0:${ONIONPRESS_SOCKS_PORT/' "$INSTALL_DIR/docker/docker-compose.yml"
            echo "$new_version" | sudo tee "$INSTALL_DIR/VERSION" > /dev/null

            # Deploy updated plugins to running container
            if docker ps --format '{{.Names}}' 2>/dev/null | grep -q onionpress-wordpress; then
                for plugin in "$INSTALL_DIR/plugins/"*.php; do
                    docker cp "$plugin" "onionpress-wordpress:/var/www/html/wp-content/mu-plugins/" 2>>"$LOG_FILE"
                done
                log "Updated plugins deployed to WordPress container"
            fi

            # Pull latest docker images
            log "Pulling latest Docker images..."
            echo "  Pulling latest Docker images..."
            cd "$INSTALL_DIR/docker"
            setup_db_passwords
            docker compose pull >> "$LOG_FILE" 2>&1 || log "WARNING: docker compose pull failed"

            # Restart
            log "Restarting OnionPress..."
            echo "  Restarting OnionPress..."
            stop_containers
            start_containers
            wait_for_services
            write_status

            # Restart OnionHeaven client service if it exists
            if systemctl list-unit-files onionpress-onionheaven.service >/dev/null 2>&1; then
                sudo systemctl restart onionpress-onionheaven 2>>"$LOG_FILE" || log "WARNING: Failed to restart OnionHeaven client"
            fi

            log "Update complete: $new_version"
            echo "  Update complete! Now running OnionPress $new_version."
            ;;

        write-status)
            setup_db_passwords
            write_status
            ;;

        apply-config)
            setup_db_passwords
            apply_config_updates
            ;;

        handle-action)
            # Process action requests from the WordPress settings page
            local action
            action=$(docker exec onionpress-wordpress cat /var/lib/onionpress/requested-action 2>/dev/null || echo "")
            if [ -z "$action" ]; then
                # No action requested — just refresh logs (cheap)
                # Full status is written on-demand when the status page detects stale data
                if [ -f "$LOG_FILE" ]; then
                    tail -100 "$LOG_FILE" | docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/recent-logs.txt' 2>/dev/null
                fi
                exit 0
            fi
            docker exec onionpress-wordpress sh -c 'rm -f /var/lib/onionpress/requested-action /var/lib/onionpress/service-result.json' 2>/dev/null
            if [ "$action" != "refresh-status" ]; then
                log "Handling requested action: $action"
            fi
            case "$action" in
                start)
                    setup_db_passwords
                    apply_config_updates 2>/dev/null || true
                    docker exec onionpress-wordpress sh -c 'echo start > /var/lib/onionpress/service-pending' 2>/dev/null
                    start_containers
                    wait_for_services
                    write_status
                    local containers_info
                    containers_info=$(docker ps --filter "name=onionpress" --format '{{.Names}}: {{.Status}}' 2>/dev/null | sed 's/onionpress-//g' | tr '\n' ', ' | sed 's/,$//' | sed 's/,/, /g')
                    echo '{"success":true,"action":"start","message":"Started '"$containers_info"'","completed_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                        docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/service-result.json && rm -f /var/lib/onionpress/service-pending' 2>/dev/null
                    ;;
                restart)
                    setup_db_passwords
                    apply_config_updates 2>/dev/null || true
                    # Write pending marker to shared volume before stopping (survives container restart)
                    docker exec onionpress-wordpress sh -c 'echo restart > /var/lib/onionpress/service-pending' 2>/dev/null
                    stop_containers
                    start_containers
                    wait_for_services
                    write_status
                    local containers_info
                    containers_info=$(docker ps --filter "name=onionpress" --format '{{.Names}}: {{.Status}}' 2>/dev/null | sed 's/onionpress-//g' | tr '\n' ', ' | sed 's/,$//' | sed 's/,/, /g')
                    echo '{"success":true,"action":"restart","message":"Restarted '"$containers_info"'","completed_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                        docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/service-result.json && rm -f /var/lib/onionpress/service-pending' 2>/dev/null
                    ;;
                stop)
                    setup_db_passwords
                    stop_containers
                    ;;
                check-reachability)
                    log "Running Tor reachability test..."
                    local onion_addr_test
                    onion_addr_test=$(docker exec onionpress-tor cat /var/lib/tor/hidden_service/wordpress/hostname 2>/dev/null | tr -d '\n\r ')
                    if [ -z "$onion_addr_test" ]; then
                        echo '{"reachable":false,"error":"No onion address found","tested_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                            docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/reachability-result.json' 2>/dev/null
                        log "Reachability test: no onion address"
                    else
                        local http_code
                        http_code=$(docker exec onionpress-tor-client curl -s -o /dev/null -w '%{http_code}' --max-time 60 --socks5-hostname 127.0.0.1:9050 "http://$onion_addr_test/" 2>/dev/null || echo "000")
                        local reachable=false
                        if [ "$http_code" -ge 200 ] && [ "$http_code" -lt 500 ] 2>/dev/null; then
                            reachable=true
                        fi
                        echo '{"reachable":'"$reachable"',"http_code":'"$http_code"',"address":"'"$onion_addr_test"'","tested_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                            docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/reachability-result.json' 2>/dev/null
                        log "Reachability test: $onion_addr_test -> HTTP $http_code (reachable=$reachable)"
                    fi
                    ;;
                generate-vanity)
                    log "Starting vanity address generation..."
                    setup_db_passwords
                    local vanity_prefix
                    vanity_prefix=$(grep "^ADDRESS_PREFIX=" "$DATA_DIR/config" 2>/dev/null | cut -d= -f2)
                    vanity_prefix="${vanity_prefix:-op2}"
                    local vanity_result_file="/tmp/onionpress-vanity-result.json"
                    if ! command -v mkp224o >/dev/null 2>&1; then
                        echo '{"success":false,"error":"mkp224o is not installed. Install it with: sudo apt install -y gcc libsodium-dev autoconf && cd /tmp && git clone https://github.com/cathugger/mkp224o && cd mkp224o && ./autogen.sh && ./configure && make && sudo cp mkp224o /usr/local/bin/","generated_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                            docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/vanity-result.json' 2>/dev/null
                        log "Vanity generation failed: mkp224o not installed"
                    else
                        local vanity_output_dir
                        vanity_output_dir=$(mktemp -d)
                        log "Generating vanity address with prefix: $vanity_prefix (this may take a while)..."
                        if mkp224o -n 1 -d "$vanity_output_dir" "$vanity_prefix" >> "$LOG_FILE" 2>&1; then
                            local vanity_addr_dir
                            vanity_addr_dir=$(find "$vanity_output_dir" -maxdepth 1 -type d -name "*.onion" | head -1)
                            if [ -n "$vanity_addr_dir" ] && [ -f "$vanity_addr_dir/hs_ed25519_secret_key" ]; then
                                local vanity_address
                                vanity_address=$(basename "$vanity_addr_dir")
                                # Import the key using the existing import flow
                                local vanity_b32_key
                                vanity_b32_key=$(python3 -c "import base64; print(base64.b32encode(open('$vanity_addr_dir/hs_ed25519_secret_key','rb').read()).decode())")
                                # Non-interactive import: skip confirmation, force replace
                                stop_containers 2>/dev/null || true
                                docker volume rm onionpress-arti-state >> "$LOG_FILE" 2>&1 || true
                                docker volume rm onionpress-tor-keys >> "$LOG_FILE" 2>&1 || true
                                rm -rf "$DATA_DIR/shared/vanity-keys/"
                                # Run import-key logic inline (without interactive prompt)
                                import_key_noninteractive "$vanity_b32_key"
                                start_containers
                                wait_for_services
                                write_status
                                echo '{"success":true,"address":"'"$vanity_address"'","generated_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                                    docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/vanity-result.json' 2>/dev/null
                                log "Vanity address generated and imported: $vanity_address"
                            else
                                echo '{"success":false,"error":"mkp224o did not produce a key","generated_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                                    docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/vanity-result.json' 2>/dev/null
                                log "Vanity generation failed: no key produced"
                            fi
                        else
                            echo '{"success":false,"error":"mkp224o failed","generated_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                                docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/vanity-result.json' 2>/dev/null
                            log "Vanity generation failed: mkp224o error"
                        fi
                        rm -rf "$vanity_output_dir"
                    fi
                    ;;
                import-key-file)
                    log "Processing key file import from settings page..."
                    setup_db_passwords
                    local key_data
                    key_data=$(docker exec onionpress-wordpress cat /var/lib/onionpress/import-key-data 2>/dev/null || echo "")
                    docker exec onionpress-wordpress sh -c 'rm -f /var/lib/onionpress/import-key-data' 2>/dev/null
                    if [ -z "$key_data" ]; then
                        echo '{"success":false,"error":"No key data found","imported_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                            docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/import-result.json' 2>/dev/null
                        log "Key import failed: no key data"
                    else
                        stop_containers 2>/dev/null || true
                        docker volume rm onionpress-arti-state >> "$LOG_FILE" 2>&1 || true
                        docker volume rm onionpress-tor-keys >> "$LOG_FILE" 2>&1 || true
                        rm -rf "$DATA_DIR/shared/vanity-keys/"
                        if import_key_noninteractive "$key_data"; then
                            start_containers
                            wait_for_services
                            write_status
                            local new_addr
                            new_addr=$(find "$DATA_DIR/shared/vanity-keys" -name hostname -exec cat {} \; 2>/dev/null | head -1)
                            echo '{"success":true,"address":"'"$new_addr"'","imported_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                                docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/import-result.json' 2>/dev/null
                            log "Key imported successfully: $new_addr"
                        else
                            echo '{"success":false,"error":"Key import failed - invalid key data","imported_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                                docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/import-result.json' 2>/dev/null
                            start_containers
                            wait_for_services
                            write_status
                            log "Key import failed: invalid key data"
                        fi
                    fi
                    ;;
                create-backup)
                    log "Creating backup from settings page..."
                    setup_db_passwords
                    local bp_password
                    bp_password=$(docker exec onionpress-wordpress cat /var/lib/onionpress/backup-password 2>/dev/null || echo "")
                    docker exec onionpress-wordpress sh -c 'rm -f /var/lib/onionpress/backup-password' 2>/dev/null
                    if [ -z "$bp_password" ]; then
                        echo '{"success":false,"error":"No password provided","created_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                            docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/backup-result.json' 2>/dev/null
                        log "Backup failed: no password"
                    else
                        local bp_onion
                        bp_onion=$(docker exec onionpress-tor cat /var/lib/tor/hidden_service/wordpress/hostname 2>/dev/null | tr -d '\n\r ' | sed 's/\.onion//' | cut -c1-8 || echo "site")
                        local bp_filename="OnionPress-${bp_onion}-$(date +%Y-%m-%d-%H-%M).zip"
                        local bp_path="/tmp/$bp_filename"
                        if create_backup "$bp_password" "$bp_path" 2>>"$LOG_FILE"; then
                            # Copy zip into the WordPress container for download
                            docker cp "$bp_path" "onionpress-wordpress:/var/lib/onionpress/$bp_filename" 2>>"$LOG_FILE"
                            docker exec onionpress-wordpress chown www-data:www-data "/var/lib/onionpress/$bp_filename" 2>/dev/null
                            rm -f "$bp_path"
                            echo '{"success":true,"filename":"'"$bp_filename"'","created_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                                docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/backup-result.json' 2>/dev/null
                            log "Backup created: $bp_filename"
                        else
                            rm -f "$bp_path"
                            echo '{"success":false,"error":"Backup failed — check logs","created_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                                docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/backup-result.json' 2>/dev/null
                            log "Backup failed"
                        fi
                    fi
                    ;;
                restore-backup)
                    log "Restoring from backup via settings page..."
                    setup_db_passwords
                    local rp_password
                    rp_password=$(docker exec onionpress-wordpress cat /var/lib/onionpress/restore-password 2>/dev/null || echo "")
                    docker exec onionpress-wordpress sh -c 'rm -f /var/lib/onionpress/restore-password' 2>/dev/null
                    local rp_file="/var/lib/onionpress/restore-upload.zip"
                    # Copy the uploaded zip out of the container
                    local rp_local="/tmp/onionpress-restore-$$.zip"
                    docker cp "onionpress-wordpress:$rp_file" "$rp_local" 2>>"$LOG_FILE"
                    docker exec onionpress-wordpress sh -c "rm -f $rp_file" 2>/dev/null
                    if [ -z "$rp_password" ] || [ ! -f "$rp_local" ]; then
                        rm -f "$rp_local"
                        echo '{"success":false,"error":"Missing password or backup file","restored_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                            docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/restore-result.json' 2>/dev/null
                        log "Restore failed: missing password or file"
                    else
                        local rp_addr
                        if rp_addr=$(restore_backup "$rp_password" "$rp_local" 2>>"$LOG_FILE"); then
                            rm -f "$rp_local"
                            # Restart to pick up restored keys
                            stop_containers 2>/dev/null || true
                            start_containers
                            wait_for_services
                            write_status
                            echo '{"success":true,"address":"'"$rp_addr"'","restored_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                                docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/restore-result.json' 2>/dev/null
                            log "Restore complete: $rp_addr"
                        else
                            rm -f "$rp_local"
                            echo '{"success":false,"error":"Restore failed — wrong password or corrupt backup","restored_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                                docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/restore-result.json' 2>/dev/null
                            log "Restore failed"
                        fi
                    fi
                    ;;
                refresh-status)
                    setup_db_passwords
                    write_status
                    ;;
                update)
                    log "Update requested from settings page..."
                    # Run the update command and capture result
                    if "$0" update >> "$LOG_FILE" 2>&1; then
                        local updated_ver
                        updated_ver=$(cat "$INSTALL_DIR/VERSION" 2>/dev/null || echo "unknown")
                        echo '{"success":true,"version":"'"$updated_ver"'","updated_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                            docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/update-result.json' 2>/dev/null
                        log "Update complete: $updated_ver"
                    else
                        echo '{"success":false,"error":"Update failed — check logs","updated_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'"}' | \
                            docker exec -i onionpress-wordpress sh -c 'cat > /var/lib/onionpress/update-result.json' 2>/dev/null
                        log "Update failed"
                    fi
                    ;;
                *)
                    log "Unknown action: $action"
                    ;;
            esac
            ;;

        *)
            echo "Usage: $0 {start|stop|restart|status|address|import-key|backup|restore|update|logs|write-status|apply-config|handle-action}"
            exit 1
            ;;
    esac
}

main "$@"
