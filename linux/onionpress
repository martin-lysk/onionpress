# ─── Archive.org credential exchange ─────────────────────────────────

# Convert Archive.org login (email/username + password) into S3 API keys.
# Sets ia_s3_access and ia_s3_secret on success, empty on failure.
fetch_archive_s3_keys() {
    local ia_email="$1" ia_pass="$2"
    ia_s3_access=""
    ia_s3_secret=""

    local response
    response=$(curl -s -X POST \
        -H "User-Agent: OnionPress (+https://github.com/brewsterkahle/onionpress)" \
        -d "email=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$ia_email'))")" \
        -d "password=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$ia_pass'))")" \
        "https://archive.org/services/xauthn/?op=login" 2>/dev/null) || return 1

    local success
    success=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('success',''))" 2>/dev/null)
    if [ "$success" != "True" ]; then
        local reason
        reason=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('values',{}).get('reason','unknown'))" 2>/dev/null)
        log "Archive.org login failed: $reason"
        return 1
    fi

    # Try S3 keys from login response
    ia_s3_access=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('values',{}).get('s3',{}).get('access',''))" 2>/dev/null)
    ia_s3_secret=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('values',{}).get('s3',{}).get('secret',''))" 2>/dev/null)

    if [ -n "$ia_s3_access" ] && [ -n "$ia_s3_secret" ]; then
        return 0
    fi

    # Fallback: fetch S3 keys separately using cookies
    local sig user
    sig=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('values',{}).get('cookies',{}).get('logged-in-sig',''))" 2>/dev/null)
    user=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('values',{}).get('cookies',{}).get('logged-in-user',''))" 2>/dev/null)

    if [ -n "$sig" ] && [ -n "$user" ]; then
        local s3_response
        s3_response=$(curl -s \
            -H "User-Agent: OnionPress (+https://github.com/brewsterkahle/onionpress)" \
            -H "Cookie: logged-in-sig=$sig; logged-in-user=$user" \
            "https://archive.org/account/s3.php?output_json=1" 2>/dev/null)
        ia_s3_access=$(echo "$s3_response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('key',{}).get('s3accesskey',''))" 2>/dev/null)
        ia_s3_secret=$(echo "$s3_response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('key',{}).get('s3secretkey',''))" 2>/dev/null)
        if [ -n "$ia_s3_access" ] && [ -n "$ia_s3_secret" ]; then
            return 0
        fi
    fi

    log "Archive.org login succeeded but could not retrieve S3 keys"
    return 1
}

# ─── First-time WordPress setup ──────────────────────────────────────

# Usage: setup_wordpress_interactive [--user USER] [--pass PASS] [--title TITLE] [--ia-account EMAIL] [--ia-password PASS]
# If args are provided, runs non-interactively. Otherwise prompts.
setup_wordpress_interactive() {
    local wp_user="" wp_pass="" wp_email="" wp_title="OnionPress"
    local ia_access="" ia_secret=""

    # Parse optional arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            --user)        wp_user="$2";    shift 2 ;;
            --pass)        wp_pass="$2";    shift 2 ;;
            --title)       wp_title="$2";   shift 2 ;;
            --ia-account)  ia_access="$2";  shift 2 ;;
            --ia-password) ia_secret="$2";  shift 2 ;;
            *) shift ;;
        esac
    done

    # If credentials not provided, prompt interactively
    if [ -z "$wp_user" ] || [ -z "$wp_pass" ]; then
        echo ""
        echo "  ======================================="
        echo "  OnionPress First-Time Setup"
        echo "  ======================================="
        echo ""
        echo "  Create your WordPress admin account."
        echo "  You'll use these credentials to log in at /wp-admin."
        echo ""

        if [ -z "$wp_user" ]; then
            while [ -z "$wp_user" ]; do
                printf "  Admin username: "
                read wp_user
                if [ -z "$wp_user" ]; then
                    echo "  Username cannot be empty."
                fi
            done
        fi

        if [ -z "$wp_pass" ]; then
            local wp_pass2=""
            while [ -z "$wp_pass" ]; do
                printf "  Admin password: "
                stty -echo 2>/dev/null
                read wp_pass
                stty echo 2>/dev/null
                echo ""
                if [ -z "$wp_pass" ]; then
                    echo "  Password cannot be empty."
                    continue
                fi
                printf "  Confirm password: "
                stty -echo 2>/dev/null
                read wp_pass2
                stty echo 2>/dev/null
                echo ""
                if [ "$wp_pass" != "$wp_pass2" ]; then
                    echo "  Passwords do not match. Try again."
                    wp_pass=""
                fi
            done
        fi

        printf "  Site title [OnionPress]: "
        read wp_title_input
        if [ -n "$wp_title_input" ]; then
            wp_title="$wp_title_input"
        fi

        # Archive.org credentials for Wayback Machine archiving
        echo ""
        echo "  Archive.org credentials (for Wayback Machine archiving)."
        echo "  Press Enter to skip (can be set later in Settings)."
        echo ""
        if [ -z "$ia_access" ]; then
            printf "  Archive.org account (username or email): "
            read ia_access
        fi
        if [ -n "$ia_access" ] && [ -z "$ia_secret" ]; then
            printf "  Archive.org password: "
            stty -echo 2>/dev/null
            read ia_secret
            stty echo 2>/dev/null
            echo ""
        fi
    fi

    if [ -z "$wp_email" ]; then
        wp_email="${wp_user}@onionpress.local"
    fi

    echo ""
    echo "  Installing WordPress..."
    log "Running WP-CLI core install for first-time setup"

    if docker exec onionpress-wordpress wp core install \
        --url="http://localhost" \
        --title="$wp_title" \
        --admin_user="$wp_user" \
        --admin_password="$wp_pass" \
        --admin_email="$wp_email" \
        --skip-email \
        --allow-root >> "$LOG_FILE" 2>&1; then
        log "WordPress installed successfully via WP-CLI"
        echo "  WordPress installed successfully!"
    else
        log "ERROR: WP-CLI core install failed"
        echo "  ERROR: WordPress installation failed. Check $LOG_FILE for details."
        echo "  You can complete setup manually at http://$(hostname -I 2>/dev/null | awk '{print $1}' || echo localhost):${ONIONPRESS_WP_PORT}"
        return 1
    fi

    # Convert Archive.org login to S3 API keys and save to wp_options
    if [ -n "$ia_access" ] && [ -n "$ia_secret" ]; then
        echo "  Logging in to Archive.org..."
        local ia_s3_access="" ia_s3_secret=""
        if fetch_archive_s3_keys "$ia_access" "$ia_secret"; then
            docker exec onionpress-wordpress wp option update onionpress_archive_s3_access "$ia_s3_access" --allow-root >> "$LOG_FILE" 2>&1
            docker exec onionpress-wordpress wp option update onionpress_archive_s3_secret "$ia_s3_secret" --allow-root >> "$LOG_FILE" 2>&1
            log "Archive.org S3 keys saved (from login)"
            echo "  Archive.org credentials saved."
        else
            echo "  WARNING: Archive.org login failed. You can set credentials later in Settings."
            log "Archive.org login failed during setup — skipping S3 key save"
        fi
    fi
}

# ─── OnionHeaven farm (takeover containers) ─────────────────────────

# Image used for takeover workers (same as main tor image)
ONIONHEAVEN_IMAGE="${ONIONHEAVEN_IMAGE:-ghcr.io/brewsterkahle/onionpress-tor:latest}"
ONIONHEAVEN_FARM_MONITOR_PID=""

_start_takeover_worker() {
    local idx="$1"
    local name="onionheaven-takeover-${idx}"
    local vol="onionpress-arti-state-takeover-${idx}"

    docker rm -f "$name" >> "$LOG_FILE" 2>&1 || true

    if docker run -d \
        --name "$name" \
        --network onionpress-network \
        --ulimit nofile=10000:10000 \
        -e TZ="${TZ:-UTC}" \
        -e TAKEOVER_WORKER=1 \
        -e CONTAINER_NAME="$name" \
        -e MAX_TAKEOVER_SERVICES="${ONIONHEAVEN_MAX_SERVICES:-50}" \
        -v "${vol}:/var/lib/arti/" \
        -v "onionpress-persistent-data:/var/lib/onionpress" \
        --restart unless-stopped \
        "$ONIONHEAVEN_IMAGE" >> "$LOG_FILE" 2>&1; then
        log "OnionHeaven farm: started takeover worker $name"
    else
        log "WARNING: Failed to start takeover worker $name"
        return 1
    fi
}

start_onionheaven_farm() {
    # Start with 0 takeover workers — they'll be spawned on demand when
    # the heartbeat monitor writes to farm_scale_requests.
    log "OnionHeaven farm: launching scaling monitor (0 initial workers)"

    _onionheaven_farm_monitor &
    ONIONHEAVEN_FARM_MONITOR_PID=$!
}

_onionheaven_farm_monitor() {
    local next_takeover=0
    local db="/var/lib/onionpress/onionheaven/registry.db"
    local hub_promoted=false

    # Auto-detect hub mode: if we have enough registered sites, bump intro points
    # by restarting the tor container with ONIONHEAVEN_HUB=1. Only done once.
    local HUB_THRESHOLD="${ONIONHEAVEN_HUB_THRESHOLD:-5}"

    while true; do
        sleep 30

        # Auto-promote to hub mode when registration count crosses threshold
        if [ "$hub_promoted" = "false" ] && [ "$ONIONHEAVEN_HUB" != "1" ]; then
            local reg_count
            reg_count=$(docker exec onionheaven sqlite3 "$db" \
                "SELECT COUNT(*) FROM registry WHERE status='online'" 2>/dev/null) || reg_count=0
            if [ "$reg_count" -ge "$HUB_THRESHOLD" ] 2>/dev/null; then
                log "OnionHeaven farm: $reg_count registered sites >= $HUB_THRESHOLD — promoting to hub mode (10 intro points)"
                export ONIONHEAVEN_HUB="1"
                # Restart tor container to pick up increased intro points
                cd "$DOCKER_DIR"
                docker compose up -d tor >> "$LOG_FILE" 2>&1 || log "WARNING: Failed to restart tor for hub mode"
                hub_promoted=true
            fi
        fi

        # Check for unfulfilled scale-up requests
        local requests
        requests=$(docker exec onionheaven sqlite3 "$db" \
            "SELECT id, worker_type FROM farm_scale_requests WHERE fulfilled_at IS NULL ORDER BY id" 2>/dev/null) || continue

        if [ -z "$requests" ]; then
            continue
        fi

        # Memory guard: skip scale-up if host memory usage >85%
        local mem_pct
        mem_pct=$(awk '/MemTotal/{t=$2} /MemAvailable/{a=$2} END{printf "%d", (1-a/t)*100}' /proc/meminfo 2>/dev/null) || mem_pct=0
        if [ "$mem_pct" -gt 85 ] 2>/dev/null; then
            log "OnionHeaven farm: skipping scale-up — memory at ${mem_pct}% (>85%)"
            while IFS='|' read -r req_id req_type; do
                local now
                now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
                docker exec onionheaven sqlite3 "$db" \
                    "UPDATE farm_scale_requests SET fulfilled_at = '${now}' WHERE id = ${req_id}" \
                    >> "$LOG_FILE" 2>&1 || true
            done <<< "$requests"
            continue
        fi

        # Process each request (format: "id|worker_type" per line)
        while IFS='|' read -r req_id req_type; do
            case "$req_type" in
                takeover)
                    log "OnionHeaven farm: scaling up — adding 2 takeover workers (starting at index $next_takeover)"
                    _start_takeover_worker "$next_takeover"
                    _start_takeover_worker "$((next_takeover + 1))"
                    next_takeover=$((next_takeover + 2))
                    ;;
                *)
                    log "WARNING: Unknown farm scale request type: $req_type"
                    ;;
            esac

            local now
            now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
            docker exec onionheaven sqlite3 "$db" \
                "UPDATE farm_scale_requests SET fulfilled_at = '${now}' WHERE id = ${req_id}" \
                >> "$LOG_FILE" 2>&1 || true
        done <<< "$requests"
    done
}

stop_onionheaven_farm() {
    # Stop the scaling monitor
    if [ -n "$ONIONHEAVEN_FARM_MONITOR_PID" ] && kill -0 "$ONIONHEAVEN_FARM_MONITOR_PID" 2>/dev/null; then
        kill "$ONIONHEAVEN_FARM_MONITOR_PID" 2>/dev/null || true
        wait "$ONIONHEAVEN_FARM_MONITOR_PID" 2>/dev/null || true
        ONIONHEAVEN_FARM_MONITOR_PID=""
    fi

    # Stop all takeover containers
    for container in $(docker ps -a --format '{{.Names}}' 2>/dev/null | grep -E '^onionheaven-takeover-[0-9]+$'); do
        docker stop "$container" >> "$LOG_FILE" 2>&1 || true
        docker rm "$container" >> "$LOG_FILE" 2>&1 || true
        log "OnionHeaven farm: stopped $container"
    done
}

