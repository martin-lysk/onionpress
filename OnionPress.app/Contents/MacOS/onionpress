# Function to set up OnionHeaven (onionheaven mode only)
# Registration API now runs in the onionheaven container (onionheaven-server.py),
# which creates its own data directories on the shared volume at startup.
install_onionheaven_plugin() {
    if [ "$ONIONHEAVEN" != "1" ]; then
        return 0
    fi

    # Clean up old PHP mu-plugins if they exist (migrated to onionheaven-server.py)
    docker exec onionpress-wordpress sh -c '
        rm -f /var/www/html/wp-content/mu-plugins/onionheaven-register.php \
              /var/www/html/wp-content/mu-plugins/onionheaven-crypto.php \
              /var/www/html/wp-content/mu-plugins/onionheaven-db.php
    ' >> "$LOG_FILE" 2>&1 || true

    # Clean up old crypto artifacts from shared volume (encryption dropped)
    docker exec onionpress-wordpress sh -c '
        rm -f /var/lib/onionpress/onionheaven/.master-key-unlocked \
              /var/lib/onionpress/onionheaven/master-key.json
    ' >> "$LOG_FILE" 2>&1 || true

    return 0
}

# Function to start containers
start_containers() {
    log "Starting OnionPress containers..."

    cd "$DOCKER_DIR"

    # Handle pending key import (volume couldn't be removed when Docker wasn't running)
    if [ -f "$DATA_DIR/.import-key-pending" ]; then
        log "Pending key import detected — removing old arti-state volume..."
        docker volume rm onionpress-arti-state >> "$LOG_FILE" 2>&1 || true
        if docker volume ls --format '{{.Name}}' 2>/dev/null | grep -q '^onionpress-arti-state$'; then
            log "Volume still in use — force-removing containers using it..."
            docker rm -f $(docker ps -aq --filter volume=onionpress-arti-state) >> "$LOG_FILE" 2>&1 || true
            docker volume rm onionpress-arti-state >> "$LOG_FILE" 2>&1 || true
            if docker volume ls --format '{{.Name}}' 2>/dev/null | grep -q '^onionpress-arti-state$'; then
                log "ERROR: Could not remove old arti-state volume"
            fi
        fi
        # Also remove old tor-keys volume if it exists (migration leftover)
        docker volume rm onionpress-tor-keys >> "$LOG_FILE" 2>&1 || true
        rm -f "$DATA_DIR/.import-key-pending"
    fi

    # Check if this is first run (no arti-state volume exists)
    if ! docker volume ls | grep -q "onionpress-arti-state"; then
        log "First run detected - generating custom onion address..."

        # Read address prefix from config, default to "op2"
        # Fall back to old VANITY_PREFIX for migration from older configs
        ADDRESS_PREFIX="op2"
        if [ -f "$DATA_DIR/config" ]; then
            CUSTOM_PREFIX=$(grep "^ADDRESS_PREFIX=" "$DATA_DIR/config" | cut -d= -f2)
            if [ -z "$CUSTOM_PREFIX" ]; then
                CUSTOM_PREFIX=$(grep "^VANITY_PREFIX=" "$DATA_DIR/config" | cut -d= -f2)
            fi
            if [ ! -z "$CUSTOM_PREFIX" ]; then
                ADDRESS_PREFIX="$CUSTOM_PREFIX"
            fi
        fi

        log "Using address prefix: '$ADDRESS_PREFIX'"

        # Validate prefix: base32 only (a-z, 2-7), max 5 chars
        if [ ${#ADDRESS_PREFIX} -gt 5 ]; then
            log "ERROR: ADDRESS_PREFIX '$ADDRESS_PREFIX' is too long (${#ADDRESS_PREFIX} chars, max 5). Using default 'op2'."
            ADDRESS_PREFIX="op2"
        elif ! echo "$ADDRESS_PREFIX" | grep -qE '^[a-z2-7]+$'; then
            log "ERROR: ADDRESS_PREFIX '$ADDRESS_PREFIX' contains invalid characters. Only a-z and 2-7 allowed. Using default 'op2'."
            ADDRESS_PREFIX="op2"
        fi

        # Check for pre-existing imported key before generating a new one
        VANITY_DIR=""
        if [ -d "$DATA_DIR/shared/vanity-keys" ]; then
            VANITY_DIR=$(find "$DATA_DIR/shared/vanity-keys" -maxdepth 1 -type d -name "*.onion" | head -1)
            if [ -n "$VANITY_DIR" ]; then
                log "Using pre-imported key: $(basename "$VANITY_DIR")"
            fi
        fi

        # Generate custom onion address if no imported key found
        if [ -z "$VANITY_DIR" ]; then
            if VANITY_DIR=$(generate_vanity_address "$ADDRESS_PREFIX"); then
                log "Custom onion address generated successfully"
            fi
        fi

        if [ -n "$VANITY_DIR" ]; then
            # Create arti-state volume and install OpenSSH key to Arti keystore path
            if ! docker volume create onionpress-arti-state >> "$LOG_FILE" 2>&1; then
                log "ERROR: Failed to create arti-state volume"
                return 1
            fi
            if ! docker run --rm \
                -v onionpress-arti-state:/dest \
                --mount type=bind,source="$VANITY_DIR",target=/src \
                alpine sh -c 'mkdir -p /dest/state/keystore/hss/wordpress && cp /src/ks_hs_id.ed25519_expanded_private /dest/state/keystore/hss/wordpress/ && chown -R 100:100 /dest/state && chmod 700 /dest/state /dest/state/keystore /dest/state/keystore/hss /dest/state/keystore/hss/wordpress && chmod 600 /dest/state/keystore/hss/wordpress/*' >> "$LOG_FILE" 2>&1; then
                log "ERROR: Failed to copy address key to arti-state volume"
                return 1
            fi

            log "Address key installed to arti-state volume"
            log "Onion address: $(cat "$VANITY_DIR/hostname" 2>/dev/null || basename "$VANITY_DIR")"
        else
            log "Using random onion address"
        fi
    else
        # Not first run — check for prefix mismatch
        # Read configured prefix (same logic as first-run block)
        ADDRESS_PREFIX="op2"
        if [ -f "$DATA_DIR/config" ]; then
            CUSTOM_PREFIX=$(grep "^ADDRESS_PREFIX=" "$DATA_DIR/config" | cut -d= -f2)
            if [ -z "$CUSTOM_PREFIX" ]; then
                CUSTOM_PREFIX=$(grep "^VANITY_PREFIX=" "$DATA_DIR/config" | cut -d= -f2)
            fi
            if [ -n "$CUSTOM_PREFIX" ]; then
                ADDRESS_PREFIX="$CUSTOM_PREFIX"
            fi
        fi

        # Validate prefix: base32 only (a-z, 2-7), max 5 chars
        if [ ${#ADDRESS_PREFIX} -gt 5 ]; then
            log "WARNING: ADDRESS_PREFIX '$ADDRESS_PREFIX' is too long (max 5). Using default 'op2'."
            ADDRESS_PREFIX="op2"
        elif ! echo "$ADDRESS_PREFIX" | grep -qE '^[a-z2-7]+$'; then
            log "WARNING: ADDRESS_PREFIX '$ADDRESS_PREFIX' contains invalid characters. Using default 'op2'."
            ADDRESS_PREFIX="op2"
        fi

        # Get current onion address from vanity-keys directory
        CURRENT_ADDR=""
        if [ -d "$DATA_DIR/shared/vanity-keys" ]; then
            CURRENT_DIR=$(find "$DATA_DIR/shared/vanity-keys" -maxdepth 1 -type d -name "*.onion" | head -1)
            if [ -n "$CURRENT_DIR" ]; then
                CURRENT_ADDR=$(basename "$CURRENT_DIR")
            fi
        fi

        # Compare prefix if we have a current address
        if [ -n "$CURRENT_ADDR" ]; then
            ADDR_BASE="${CURRENT_ADDR%.onion}"
            case "$ADDR_BASE" in
                ${ADDRESS_PREFIX}*)
                    # Prefix matches — nothing to do
                    ;;
                *)
                    log "PREFIX MISMATCH: current address '$CURRENT_ADDR' does not start with '$ADDRESS_PREFIX'"
                    log "Regenerating onion address with new prefix..."

                    # Stop and remove containers that use the arti-state volume
                    docker compose down >> "$LOG_FILE" 2>&1 || true
                    docker volume rm onionpress-arti-state >> "$LOG_FILE" 2>&1 || true

                    # Remove old vanity-key directory
                    rm -rf "$DATA_DIR/shared/vanity-keys"

                    # Generate new address
                    if VANITY_DIR=$(generate_vanity_address "$ADDRESS_PREFIX"); then
                        log "New address generated successfully"

                        # Create arti-state volume and install key (same as first-run)
                        if ! docker volume create onionpress-arti-state >> "$LOG_FILE" 2>&1; then
                            log "ERROR: Failed to create arti-state volume"
                            return 1
                        fi
                        if ! docker run --rm \
                            -v onionpress-arti-state:/dest \
                            --mount type=bind,source="$VANITY_DIR",target=/src \
                            alpine sh -c 'mkdir -p /dest/state/keystore/hss/wordpress && cp /src/ks_hs_id.ed25519_expanded_private /dest/state/keystore/hss/wordpress/ && chown -R 100:100 /dest/state && chmod 700 /dest/state /dest/state/keystore /dest/state/keystore/hss /dest/state/keystore/hss/wordpress && chmod 600 /dest/state/keystore/hss/wordpress/*' >> "$LOG_FILE" 2>&1; then
                            log "ERROR: Failed to copy address key to arti-state volume"
                            return 1
                        fi

                        log "Address key installed to arti-state volume"
                        log "New onion address: $(cat "$VANITY_DIR/hostname" 2>/dev/null || basename "$VANITY_DIR")"
                    else
                        log "ERROR: Failed to generate new address with prefix '$ADDRESS_PREFIX'"
                        return 1
                    fi
                    ;;
            esac
        fi
    fi

    # Update images if enabled in config
    update_images

    # Pull pre-built images from GHCR (avoids local build when both image: and build: are set)
    log "Pulling pre-built images..."
    docker compose --profile onionheaven pull >> "$LOG_FILE" 2>&1 || log "WARNING: Failed to pull images (will build locally)"

    # Always start WordPress and DB first
    local max_attempts=3
    local attempt=1
    while [ $attempt -le $max_attempts ]; do
        if docker compose up -d --pull always wordpress db tor-client >> "$LOG_FILE" 2>&1; then
            break
        fi
        log "WARNING: 'docker compose up -d --pull always wordpress db tor-client' failed (attempt $attempt/$max_attempts). Check $LOG_FILE for details."
        if [ $attempt -eq $max_attempts ]; then
            log "ERROR: 'docker compose up -d --pull always wordpress db tor-client' failed after $max_attempts attempts."
            return 1
        fi
        attempt=$((attempt + 1))
        sleep 5
    done
    log "WordPress, DB, and Tor client containers starting"

    # Wait for WordPress container to be ready before checking install status
    local wp_wait=0
    while [ $wp_wait -lt 60 ]; do
        if curl -s --max-time 3 "http://localhost:${ONIONPRESS_WP_PORT:-8080}" >/dev/null 2>&1; then
            break
        fi
        sleep 2
        wp_wait=$((wp_wait + 2))
    done

    # Check if WordPress is already set up (admin account created)
    # Retry a few times — the DB may still be warming up even though
    # WordPress HTTP is responding (wp core is-installed needs a live DB)
    local wp_installed=false
    local wp_check=0
    while [ $wp_check -lt 5 ]; do
        if wp_is_installed; then
            wp_installed=true
            break
        fi
        sleep 2
        wp_check=$((wp_check + 1))
    done

    # Detect onionheaven mode BEFORE starting Tor so ONIONHEAVEN env var
    # is set when docker-compose creates the tor container (exposes port 8083)
    cd "$DOCKER_DIR"
    detect_onionheaven_mode || true

    if $wp_installed; then
        log "WordPress is installed — starting Tor"
        docker compose up -d --pull always tor >> "$LOG_FILE" 2>&1 || log "ERROR: Failed to start tor container"
    else
        log "WordPress not yet installed — waiting for setup (Tor NOT started)"
    fi

    # Install Internet Archive Wayback Machine Link Fixer plugin
    install_ia_plugin

    # Configure IA plugin options (link fixer, wizard completion)
    configure_ia_plugin

    # Install multisite domain mapping PHP files (sunrise.php + mu-plugin)
    install_multisite_domain_map

    # Ensure multisite is active (converts single-site installs if needed)
    ensure_multisite

    # Fix permissions for onionpress persistent data directory
    fix_onionpress_permissions

    # Install OnionHeaven plugin if applicable
    cd "$DOCKER_DIR"
    install_onionheaven_plugin

    # Start OnionHeaven farm workers (poll + takeover containers)
    cd "$DOCKER_DIR"
    start_onionheaven_farm

    # Conditionally start Cloudflare Tunnel
    if [ -n "$CLOUDFLARE_TUNNEL_TOKEN" ]; then
        log "Cloudflare Tunnel enabled, starting cloudflared..."
        docker compose $CF_COMPOSE up -d --pull always cloudflared >> "$LOG_FILE" 2>&1 || log "ERROR: Failed to start cloudflared container"
    else
        # Stop cloudflared if it was previously running but token was removed
        docker stop onionpress-cloudflared 2>/dev/null || true
    fi
}

# Function to stop containers
stop_containers() {
    log "Stopping OnionPress containers..."
    # Stop farm containers first (they depend on the onionheaven container's DB)
    stop_onionheaven_farm
    cd "$DOCKER_DIR"
    # Stop all containers (OnionHeaven via profile, cloudflared via override file if token set)
    docker compose $CF_COMPOSE --profile onionheaven down 2>&1 | tee -a "$LOG_FILE"
    log "Containers stopped"
}

# Function to get container status
get_status() {
    cd "$DOCKER_DIR"
    # Convert newline-delimited JSON to JSON array
    docker compose ps --format json 2>/dev/null | jq -s '.' 2>/dev/null || echo "[]"
}

# Function to get onion address (non-blocking, single attempt)
get_onion_address() {
    cd "$DOCKER_DIR"
    ONION_ADDR=$(docker compose exec -T tor cat /var/lib/tor/hidden_service/wordpress/hostname 2>/dev/null || echo "")
    if [ ! -z "$ONION_ADDR" ]; then
        echo "$ONION_ADDR"
        return 0
    fi
    echo "Generating..."
    return 1
}

# Function to get healthcheck onion address (non-blocking, single attempt)
get_healthcheck_address() {
    cd "$DOCKER_DIR"
    local addr
    addr=$(docker compose exec -T tor cat /var/lib/tor/hidden_service/healthcheck/hostname 2>/dev/null || echo "")
    if [ ! -z "$addr" ]; then
        echo "$addr"
        # Save to data dir for menubar app to read
        echo "$addr" > "$DATA_DIR/healthcheck-address"
        return 0
    fi
    return 1
}

# Function to wait for services to be ready using active probing
wait_for_services() {
    cd "$DOCKER_DIR"
    local max_wait=120
    local waited=0
    local wp_ready=false
    local onion_ready=false
    local onion_addr=""

    log "Waiting for services to be ready (polling with curl)..."

    while [ $waited -lt $max_wait ]; do
        # Step 1: Get onion address if we don't have it yet
        if [ -z "$onion_addr" ] || [ "$onion_addr" = "Generating..." ]; then
            onion_addr=$(docker compose exec -T tor cat /var/lib/tor/hidden_service/wordpress/hostname 2>/dev/null || echo "")
        fi

        # Step 2: Check if WordPress is responding locally
        if [ "$wp_ready" = false ]; then
            if curl -s --max-time 3 "http://localhost:${ONIONPRESS_WP_PORT:-8080}" >/dev/null 2>&1; then
                log "✓ WordPress is responding on localhost:${ONIONPRESS_WP_PORT:-8080}"
                wp_ready=true

                # If WordPress is not yet installed, skip waiting for Tor
                if ! wp_is_installed; then
                    log "WordPress not installed — setup required, skipping Tor wait"
                    return 0
                fi
            fi
        fi

        # Step 3: Check Tor bootstrap and WordPress reachable from Tor container
        # (SOCKS proxy doesn't work through Colima VM port forwarding,
        # so we test the actual path: tor -> wordpress via Docker network)
        if [ "$onion_ready" = false ] && [ ! -z "$onion_addr" ] && [ "$onion_addr" != "Generating..." ]; then
            # Check Tor is bootstrapped
            if docker compose logs --tail 100 tor 2>/dev/null | grep -q -E "Bootstrapped 100% \(done\)|Sufficiently bootstrapped"; then
                # Check WordPress is reachable from Tor container
                if docker compose exec -T tor wget -q -O /dev/null --timeout=5 http://wordpress:80/ 2>/dev/null; then
                    log "✓ Onion service ready: ${onion_addr}"
                    onion_ready=true
                fi
            fi
        fi

        # Both ready — done
        if [ "$wp_ready" = true ] && [ "$onion_ready" = true ]; then
            log "All services are ready after ${waited}s"
            ONION_ADDR="$onion_addr"
            # Read and save healthcheck address
            if hc_addr=$(get_healthcheck_address); then
                log "Healthcheck address: ${hc_addr}"
            fi

            # Write onion address to shared volume for WordPress plugins
            docker exec onionpress-tor cp /var/lib/tor/hidden_service/wordpress/hostname /var/lib/onionpress/onion_address 2>>"$LOG_FILE" && \
                log "✓ Onion address written to shared volume" || \
                log "WARNING: Failed to write onion address to shared volume"

            return 0
        fi

        sleep 2
        waited=$((waited + 2))
    done

    # Timed out — report what we have
    log "WARNING: Services not fully ready after ${max_wait}s (wp=${wp_ready}, onion=${onion_ready})"
    if [ ! -z "$onion_addr" ] && [ "$onion_addr" != "Generating..." ]; then
        ONION_ADDR="$onion_addr"
    else
        ONION_ADDR="Generating..."
    fi
    return 1
}

# Main execution
main() {
    case "${1:-start}" in
        start)
            # PID lock — prevent double-starting
            if [ -f "$PIDFILE" ]; then
                old_pid=$(cat "$PIDFILE" 2>/dev/null)
                if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
                    echo "OnionPress is already running (PID $old_pid)." >&2
                    osascript -e 'display dialog "OnionPress is already running." buttons {"OK"} default button "OK" with icon caution with title "OnionPress"' 2>/dev/null || true
                    exit 1
                fi
                # Stale pid file — process no longer running
                rm -f "$PIDFILE"
            fi
            echo $$ > "$PIDFILE"
            trap 'rm -f "$PIDFILE"' EXIT INT TERM HUP

            # Pre-check: if onionheaven key is imported, ensure VM has at least 5GB + 3/4 CPUs
            local onionheaven_address="oheavenfhbohpdjijmxo3xgvvuo6eleyhhorbompoycle6x5eajlp7qd.onion"
            if [ -d "$DATA_DIR/shared/vanity-keys/$onionheaven_address" ]; then
                mkdir -p "$DATA_DIR"
                local _oh_cores
                _oh_cores=$(sysctl -n hw.ncpu 2>/dev/null || echo 4)
                _oh_cores=$(( _oh_cores * 3 / 4 ))
                [ "$_oh_cores" -lt 2 ] && _oh_cores=2

                local _cfg_changed=false
                local current_mem=$(grep "^VM_MEMORY=" "$DATA_DIR/config" 2>/dev/null | cut -d= -f2)
                if [ -z "$current_mem" ] || [ "$current_mem" -lt 8 ] 2>/dev/null; then
                    log "OnionHeaven key detected — setting VM_MEMORY to 8GB (was ${current_mem:-unset})"
                    if grep -q "^VM_MEMORY=" "$DATA_DIR/config" 2>/dev/null; then
                        sed -i.bak "s/^VM_MEMORY=.*/VM_MEMORY=8/" "$DATA_DIR/config"
                    else
                        echo "VM_MEMORY=8" >> "$DATA_DIR/config"
                    fi
                    _cfg_changed=true
                fi
                local current_cpu=$(grep "^VM_CPU=" "$DATA_DIR/config" 2>/dev/null | cut -d= -f2)
                if [ -z "$current_cpu" ] || [ "$current_cpu" -lt "$_oh_cores" ] 2>/dev/null; then
                    log "OnionHeaven key detected — setting VM_CPU to ${_oh_cores} (was ${current_cpu:-unset})"
                    if grep -q "^VM_CPU=" "$DATA_DIR/config" 2>/dev/null; then
                        sed -i.bak "s/^VM_CPU=.*/VM_CPU=${_oh_cores}/" "$DATA_DIR/config"
                    else
                        echo "VM_CPU=${_oh_cores}" >> "$DATA_DIR/config"
                    fi
                    _cfg_changed=true
                fi
            fi

            # Detect container runtime
            if ! RUNTIME=$(detect_container_runtime); then
                install_docker
                exit $?
            fi

            log "Detected container runtime: $RUNTIME"

            # Create symlink for Docker socket if needed
            # Colima forwards the socket to ~/.colima/default/docker.sock
            # but we configure DOCKER_HOST to use ~/.onionpress/colima/default/docker.sock
            # Create symlink to bridge this gap
            SOCKET_DIR="$COLIMA_HOME/default"
            SOCKET_PATH="$SOCKET_DIR/docker.sock"
            COLIMA_SOCKET="$HOME/.colima/default/docker.sock"

            if [ -S "$COLIMA_SOCKET" ]; then
                if [ ! -e "$SOCKET_PATH" ] || [ ! -S "$SOCKET_PATH" ]; then
                    log "Creating Docker socket symlink..."
                    mkdir -p "$SOCKET_DIR"
                    ln -sf "$COLIMA_SOCKET" "$SOCKET_PATH"
                    log "Docker socket symlink created: $SOCKET_PATH -> $COLIMA_SOCKET"
                fi
            fi

            # Setup database passwords (generates random passwords on first run)
            setup_db_passwords

            # Start containers
            start_containers

            # Actively poll until services are ready (replaces fixed sleep)
            wait_for_services

            log "OnionPress is running!"
            log "Onion address: $ONION_ADDR"
            log "Local access: http://localhost:${ONIONPRESS_WP_PORT:-8080}"
            log "OnionPress is now running! Check the menu bar for status."
            ;;

        stop)
            setup_db_passwords
            stop_containers
            ;;

        restart)
            setup_db_passwords
            stop_containers
            start_containers
            wait_for_services
            ;;

        status)
            get_status
            ;;

        address)
            get_onion_address
            ;;

        start-tor)
            setup_db_passwords
            cd "$DOCKER_DIR"
            # Detect onionheaven mode BEFORE starting Tor so ONIONHEAVEN env var
            # is set when docker-compose creates the tor container (exposes port 8083)
            detect_onionheaven_mode || true
            docker compose up -d --pull always tor tor-client >> "$LOG_FILE" 2>&1 || log "ERROR: Failed to start tor container"
            log "Tor containers started"
            ;;

        import-key)
            import_key "$2"
            ;;

        logs)
            cd "$DOCKER_DIR"
            docker compose logs -f
            ;;

        launch)
            # Full app launch — opens the OnionPress.app bundle, which runs the
            # launcher script (boots Colima VM, starts MenubarApp, starts containers).
            # Safe to call when already running (launcher detects and exits).
            APP_BUNDLE="$(dirname "$APP_DIR")"
            open "$APP_BUNDLE"
            ;;

        *)
            echo "Usage: $0 {start|stop|restart|status|address|start-tor|import-key|launch|logs}"
            exit 1
            ;;
    esac
}

main "$@"
