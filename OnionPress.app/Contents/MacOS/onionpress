#!/bin/bash

# OnionPress launcher script
# This script manages the WordPress + Tor onion service containers

set -e

# Clear py2app PYTHONPATH so subprocess python calls are not confused.
unset PYTHONPATH

# Ensure we run natively on Apple Silicon (not under Rosetta).
# Universal binaries inherit the parent's architecture, so if this script
# was started under Rosetta we must re-exec to get native arm64 execution.
if sysctl hw.optional.arm64 2>/dev/null | grep -q ": 1" && [ "$(uname -m)" = "x86_64" ]; then
    exec arch -arm64 "$0" "$@"
fi

# Get the directory where this script is located
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
APP_DIR="$(dirname "$SCRIPT_DIR")"
RESOURCES_DIR="$APP_DIR/Resources"
DOCKER_DIR="$RESOURCES_DIR/docker"
SCRIPTS_DIR="$RESOURCES_DIR/scripts"
DATA_DIR="$HOME/.onionpress"
BIN_DIR="$RESOURCES_DIR/bin"
COLIMA_HOME="$DATA_DIR/colima"

# Use the Python bundled inside the py2app MenubarApp so we never depend on
# system Python (which may not exist — macOS does not ship a usable python3).
# PYTHONHOME is set inline per-call (not exported) to avoid polluting the
# environment for docker, docker compose, and other child processes.
_BUNDLED_PYTHON_BIN="$RESOURCES_DIR/MenubarApp/Contents/MacOS/python"
_BUNDLED_PYTHONHOME="$RESOURCES_DIR/MenubarApp/Contents/Resources"
bundled_python() { PYTHONHOME="$_BUNDLED_PYTHONHOME" "$_BUNDLED_PYTHON_BIN" "$@"; }

# Ensure data directory exists
mkdir -p "$DATA_DIR"

# Per-user lock file to prevent the same user from double-starting.
# Only checked for 'start' — other commands (status, get, launch, etc.) are safe.
PIDFILE="$DATA_DIR/onionpress.pid"

# Detect architecture (use sysctl to get actual hardware, not process architecture)
if sysctl hw.optional.arm64 2>/dev/null | grep -q ": 1"; then
    VM_ARCH="aarch64"
elif [ "$(uname -m)" = "x86_64" ]; then
    VM_ARCH="x86_64"
fi

# Create Docker config without credential store (avoids docker-credential-osxkeychain errors)
mkdir -p "$DATA_DIR/docker-config"
if [ ! -f "$DATA_DIR/docker-config/config.json" ]; then
    cat > "$DATA_DIR/docker-config/config.json" <<'EOFCONFIG'
{
	"auths": {},
	"currentContext": "colima"
}
EOFCONFIG
fi

# Install docker-compose plugin: prefer bundled, fall back to system
mkdir -p "$DATA_DIR/docker-config/cli-plugins"
if [ -f "$BIN_DIR/docker-compose" ]; then
    ln -sf "$BIN_DIR/docker-compose" "$DATA_DIR/docker-config/cli-plugins/docker-compose"
elif [ -L "$HOME/.docker/cli-plugins/docker-compose" ] && [ ! -e "$DATA_DIR/docker-config/cli-plugins/docker-compose" ]; then
    ln -sf "$HOME/.docker/cli-plugins/docker-compose" "$DATA_DIR/docker-config/cli-plugins/docker-compose"
fi

# Create default config if it doesn't exist
if [ ! -f "$DATA_DIR/config" ]; then
    if [ -f "$RESOURCES_DIR/config-template.txt" ]; then
        cp "$RESOURCES_DIR/config-template.txt" "$DATA_DIR/config"
    else
        cat > "$DATA_DIR/config" <<EOF
ADDRESS_PREFIX=op2
INSTALL_IA_PLUGIN=yes
UPDATE_ON_LAUNCH=no
LAUNCH_ON_LOGIN=no
EOF
    fi
fi

# Prefer bundled binaries
export PATH="$BIN_DIR:$PATH"
export PYTHONDONTWRITEBYTECODE=1
export COLIMA_HOME="$COLIMA_HOME"
export LIMA_HOME="$COLIMA_HOME/_lima"
export LIMA_INSTANCE="onionpress"
export DOCKER_HOST="unix://$COLIMA_HOME/default/docker.sock"
export DOCKER_CONFIG="$DATA_DIR/docker-config"
export TZ="$(readlink /etc/localtime 2>/dev/null | sed 's|.*/zoneinfo/||' || echo UTC)"

# Detect per-user port offset for multi-user support
# When multiple macOS users run OnionPress, each needs unique host ports.
# Try binding the WordPress port; if in use, bump offset by 10000.
# NOTE: Must use actual socket bind (not lsof) because lsof only shows
# the current user's processes and cannot detect ports bound by other users.
detect_port_offset() {
    local offset=0
    while true; do
        local test_port=$((8080 + offset))
        if [ $test_port -gt 65535 ]; then
            log "ERROR: No available ports (tried offsets 0-$((offset - 10000)))"
            offset=0  # fall back to default
            break
        fi
        # Try to bind the port — fails with EADDRINUSE regardless of which user owns it
        if bundled_python -c "
import socket, sys
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
try:
    s.bind(('127.0.0.1', int(sys.argv[1])))
    s.close()
except OSError:
    sys.exit(1)
" "$test_port" 2>/dev/null; then
            break
        fi
        log "Port $test_port in use, trying offset $((offset + 10000))"
        offset=$((offset + 10000))
    done
    echo "$offset"
}

# Use pre-set offset from menubar app if available, otherwise detect
if [ -z "$ONIONPRESS_PORT_OFFSET" ]; then
    ONIONPRESS_PORT_OFFSET=$(detect_port_offset)
fi
export ONIONPRESS_PORT_OFFSET
export ONIONPRESS_WP_PORT=$((8080 + ONIONPRESS_PORT_OFFSET))
export ONIONPRESS_SOCKS_PORT=$((9050 + ONIONPRESS_PORT_OFFSET))
export ONIONPRESS_PROXY_PORT=$((9077 + ONIONPRESS_PORT_OFFSET))

# Read version from Info.plist
ONIONPRESS_VERSION=$(/usr/libexec/PlistBuddy -c "Print :CFBundleShortVersionString" "$APP_DIR/Info.plist" 2>/dev/null || echo "unknown")
export ONIONPRESS_VERSION

# Read Cloudflare Tunnel token from config (empty = disabled)
CLOUDFLARE_TUNNEL_TOKEN=""
if [ -f "$DATA_DIR/config" ]; then
    _cf_token=$(grep "^CLOUDFLARE_TUNNEL_TOKEN=" "$DATA_DIR/config" | cut -d= -f2)
    if [ ! -z "$_cf_token" ]; then
        CLOUDFLARE_TUNNEL_TOKEN="$_cf_token"
    fi
fi
export CLOUDFLARE_TUNNEL_TOKEN

# Build compose flags — include cloudflare override file only when token is set
if [ -n "$CLOUDFLARE_TUNNEL_TOKEN" ]; then
    CF_COMPOSE="-f docker-compose.yml -f docker-compose.cloudflare.yml"
else
    CF_COMPOSE=""
fi

# OnionHeaven mode detection — check if our .onion address matches the onionheaven address
# This env var is passed to docker-compose and controls OnionHeaven-specific behavior
export ONIONHEAVEN="0"

detect_onionheaven_mode() {
    local onionheaven_address="oheavenfhbohpdjijmxo3xgvvuo6eleyhhorbompoycle6x5eajlp7qd.onion"
    local our_address=""
    # Check vanity-keys directory first (works even before containers start)
    if [ -d "$DATA_DIR/shared/vanity-keys" ]; then
        our_address=$(basename "$(find "$DATA_DIR/shared/vanity-keys" -maxdepth 1 -type d -name "*.onion" | head -1)" 2>/dev/null)
    fi
    # Fall back to reading from the tor container if vanity-keys didn't work
    if [ -z "$our_address" ] || [ "$our_address" = "." ]; then
        our_address=$(docker compose exec -T tor cat /var/lib/tor/hidden_service/wordpress/hostname 2>/dev/null || echo "")
        our_address=$(echo "$our_address" | tr -d '\n\r ')
    fi
    if [ "$our_address" = "$onionheaven_address" ]; then
        export ONIONHEAVEN="1"
        log "OnionHeaven mode activated (address: $our_address)"

        # OnionHeaven needs more memory and CPUs for polling, takeover services, etc.
        # If VM_MEMORY is below 5GB, bump to 5GB (preserve higher values).
        # If VM_CPU is below 3/4 of host cores, bump it.
        local current_mem
        current_mem=$(grep "^VM_MEMORY=" "$DATA_DIR/config" 2>/dev/null | cut -d= -f2)
        current_mem="${current_mem:-1}"
        local oh_target_cpus
        oh_target_cpus=$(sysctl -n hw.ncpu 2>/dev/null || echo 4)
        oh_target_cpus=$(( oh_target_cpus * 3 / 4 ))
        [ "$oh_target_cpus" -lt 2 ] && oh_target_cpus=2
        local current_cpu
        current_cpu=$(grep "^VM_CPU=" "$DATA_DIR/config" 2>/dev/null | cut -d= -f2)
        current_cpu="${current_cpu:-2}"
        if [ "$current_cpu" -lt "$oh_target_cpus" ] 2>/dev/null; then
            log "OnionHeaven: VM_CPU is ${current_cpu}, increasing to ${oh_target_cpus} (3/4 of host cores)"
            if grep -q "^VM_CPU=" "$DATA_DIR/config" 2>/dev/null; then
                sed -i.bak "s/^VM_CPU=.*/VM_CPU=${oh_target_cpus}/" "$DATA_DIR/config"
            else
                echo "VM_CPU=${oh_target_cpus}" >> "$DATA_DIR/config"
            fi
        fi
        if [ "$current_mem" -lt 8 ] 2>/dev/null; then
            log "OnionHeaven: VM_MEMORY is ${current_mem}GB, increasing to 8GB for OnionHeaven workload"
            if grep -q "^VM_MEMORY=" "$DATA_DIR/config" 2>/dev/null; then
                sed -i.bak "s/^VM_MEMORY=.*/VM_MEMORY=8/" "$DATA_DIR/config"
            else
                echo "VM_MEMORY=8" >> "$DATA_DIR/config"
            fi
        fi

        # Check if the running VM needs a restart for memory or CPU changes
        local _oh_need_restart=false
        local vm_mem_kb
        vm_mem_kb=$(docker compose exec -T tor awk '/MemTotal/{print $2}' /proc/meminfo 2>/dev/null | tr -d ' \n\r')
        vm_mem_kb="${vm_mem_kb:-0}"
        if [ "$vm_mem_kb" -gt 0 ] 2>/dev/null && [ "$vm_mem_kb" -lt 7500000 ] 2>/dev/null; then
            log "OnionHeaven: VM memory too low ($(( vm_mem_kb / 1024 ))MB)"
            _oh_need_restart=true
        fi
        local vm_cpus
        vm_cpus=$(docker compose exec -T tor nproc 2>/dev/null | tr -d ' \n\r')
        vm_cpus="${vm_cpus:-0}"
        if [ "$vm_cpus" -gt 0 ] 2>/dev/null && [ "$vm_cpus" -lt "$oh_target_cpus" ] 2>/dev/null; then
            log "OnionHeaven: VM CPUs too low (${vm_cpus}, need ${oh_target_cpus})"
            _oh_need_restart=true
        fi
        if [ "$_oh_need_restart" = true ]; then
            log "OnionHeaven: restarting VM with ${oh_target_cpus} CPUs, 8GB RAM..."
            cd "$DOCKER_DIR"
            docker compose $CF_COMPOSE --profile onionheaven down >> "$LOG_FILE" 2>&1
            "$BIN_DIR/colima" stop >> "$LOG_FILE" 2>&1
            "$BIN_DIR/colima" start \
                --mount "$DATA_DIR/shared:w" \
                --cpu "$oh_target_cpus" \
                --memory 8 \
                >> "$LOG_FILE" 2>&1
            if [ $? -eq 0 ]; then
                log "OnionHeaven: VM restarted with ${oh_target_cpus} CPUs, 8GB"
                # Bring containers back up (start_containers will re-call detect_onionheaven_mode,
                # but this time the VM will have correct resources so no loop)
                docker compose up -d --pull always wordpress db >> "$LOG_FILE" 2>&1
                # Wait for WordPress to be ready
                local oh_wp_wait=0
                while [ $oh_wp_wait -lt 60 ]; do
                    if curl -s --max-time 3 "http://localhost:${ONIONPRESS_WP_PORT:-8080}" >/dev/null 2>&1; then
                        break
                    fi
                    sleep 2
                    oh_wp_wait=$((oh_wp_wait + 2))
                done
                docker compose up -d --pull always tor tor-client >> "$LOG_FILE" 2>&1
            else
                log "OnionHeaven: ERROR — VM restart failed"
            fi
        fi
        # Build OnionHeaven-aware tor image (layers new files on top of pre-built image)
        # This is fast (<5s) since the base image is already pulled and we only add scripts
        local tor_dir
        tor_dir="$(cd "$(dirname "$0")/../Resources/docker/tor" && pwd)"
        log "OnionHeaven: building tor image with onionheaven poller..."
        # Use a local-only tag so 'docker compose --pull always' for other services
        # doesn't overwrite the rebuilt image with the upstream base
        export ONIONHEAVEN_IMAGE="onionpress-tor:onionheaven"
        docker build -t "$ONIONHEAVEN_IMAGE" \
            -f - "$tor_dir" >> "$LOG_FILE" 2>&1 <<'ONIONHEAVEN_DOCKERFILE'
FROM ghcr.io/brewsterkahle/onionpress-tor:latest
COPY entrypoint.sh /entrypoint.sh
COPY arti-onionheaven.toml /etc/arti/arti-onionheaven.toml
COPY onion_auth.py /onion_auth.py
COPY onionheaven_common.py /onionheaven_common.py
COPY onionheaven-heartbeat.py /onionheaven-heartbeat.py
COPY onionheaven-server.py /onionheaven-server.py
COPY onionheaven-tor-manager.sh /onionheaven-tor-manager.sh
COPY onionheaven-takeover-worker.py /onionheaven-takeover-worker.py
COPY onionheaven-redirect.sh /onionheaven-redirect.sh
RUN chmod +x /entrypoint.sh /onionheaven-heartbeat.py /onionheaven-server.py /onionheaven-tor-manager.sh /onionheaven-takeover-worker.py /onionheaven-redirect.sh
ONIONHEAVEN_DOCKERFILE
        # Remove old tor-polling container if it exists (renamed to onionheaven)
        if docker inspect onionpress-tor-polling >/dev/null 2>&1; then
            log "OnionHeaven: removing old onionpress-tor-polling container..."
            docker stop onionpress-tor-polling >> "$LOG_FILE" 2>&1 || true
            docker rm onionpress-tor-polling >> "$LOG_FILE" 2>&1 || true
        fi

        # Start onionheaven container (ONIONHEAVEN_IMAGE env var tells compose to use our local tag)
        # No --pull for onionheaven — we just built it locally
        if docker compose --profile onionheaven up -d onionheaven >> "$LOG_FILE" 2>&1; then
            log "OnionHeaven: started onionheaven container"
        else
            log "WARNING: Failed to start onionheaven container"
        fi
        return 0
    fi
    return 1
}

# OnionHeaven farm — takeover worker containers
# Each gets its own Arti instance (own guard pool) to prevent circuit exhaustion.
# Starts with 2, scales up by 2 when threshold is hit.
# Poll workers are no longer needed — heartbeat-based monitoring scans DB timestamps.
# ONIONHEAVEN_IMAGE is set by detect_onionheaven_mode() to the locally-built tag
ONIONHEAVEN_FARM_MONITOR_PID=""

# Start a single takeover worker container
_start_takeover_worker() {
    local idx="$1"
    local name="onionheaven-takeover-${idx}"
    local vol="onionpress-arti-state-takeover-${idx}"

    docker rm -f "$name" >> "$LOG_FILE" 2>&1 || true

    if docker run -d \
        --name "$name" \
        --network onionpress-network \
        --ulimit nofile=10000:10000 \
        -e TZ="${TZ:-UTC}" \
        -e TAKEOVER_WORKER=1 \
        -e CONTAINER_NAME="$name" \
        -e MAX_TAKEOVER_SERVICES=3 \
        -v "${vol}:/var/lib/arti/" \
        -v "onionpress-persistent-data:/var/lib/onionpress" \
        --restart unless-stopped \
        "$ONIONHEAVEN_IMAGE" >> "$LOG_FILE" 2>&1; then
        log "OnionHeaven farm: started takeover worker $name"
    else
        log "WARNING: Failed to start takeover worker $name"
        return 1
    fi
}

start_onionheaven_farm() {
    if [ "$ONIONHEAVEN" != "1" ]; then
        return
    fi
    log "OnionHeaven farm: starting initial 2 takeover workers..."

    _start_takeover_worker 0
    _start_takeover_worker 1

    # Give containers a moment to register
    sleep 3

    log "OnionHeaven farm: initial workers started — launching scaling monitor"

    # Background monitor: checks DB for scale-up requests every 30s
    _onionheaven_farm_monitor &
    ONIONHEAVEN_FARM_MONITOR_PID=$!
}

_onionheaven_farm_monitor() {
    # Tracks the next index to use for takeover workers
    local next_takeover=2
    local db="/var/lib/onionpress/onionheaven/registry.db"

    while true; do
        sleep 30

        # Check for unfulfilled scale-up requests
        local requests
        requests=$(docker exec onionheaven sqlite3 "$db" \
            "SELECT id, worker_type FROM farm_scale_requests WHERE fulfilled_at IS NULL ORDER BY id" 2>/dev/null) || continue

        if [ -z "$requests" ]; then
            continue
        fi

        # Memory guard: skip scale-up if VM memory usage is too high (>85%)
        local vm_mem_pct
        vm_mem_pct=$(docker exec onionheaven sh -c \
            "awk '/MemTotal/{t=\$2} /MemAvailable/{a=\$2} END{printf \"%d\", (1-a/t)*100}' /proc/meminfo" 2>/dev/null) || vm_mem_pct=0
        if [ "$vm_mem_pct" -gt 85 ] 2>/dev/null; then
            log "OnionHeaven farm: skipping scale-up — VM memory at ${vm_mem_pct}% (>85%)"
            # Mark requests as fulfilled so they don't pile up
            while IFS='|' read -r req_id req_type; do
                local now
                now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
                docker exec onionheaven sqlite3 "$db" \
                    "UPDATE farm_scale_requests SET fulfilled_at = '${now}' WHERE id = ${req_id}" \
                    >> "$LOG_FILE" 2>&1 || true
            done <<< "$requests"
            continue
        fi

        # Process each request (format: "id|worker_type" per line)
        # Use here-string (<<<) to avoid subshell — variable updates persist
        while IFS='|' read -r req_id req_type; do
            case "$req_type" in
                takeover)
                    log "OnionHeaven farm: scaling up — adding 2 takeover workers (starting at index $next_takeover)"
                    _start_takeover_worker "$next_takeover"
                    _start_takeover_worker "$((next_takeover + 1))"
                    next_takeover=$((next_takeover + 2))
                    ;;
                *)
                    log "WARNING: Unknown farm scale request type: $req_type"
                    ;;
            esac

            # Mark request as fulfilled
            local now
            now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
            docker exec onionheaven sqlite3 "$db" \
                "UPDATE farm_scale_requests SET fulfilled_at = '${now}' WHERE id = ${req_id}" \
                >> "$LOG_FILE" 2>&1 || true
        done <<< "$requests"
    done
}

stop_onionheaven_farm() {
    # Stop the scaling monitor
    if [ -n "$ONIONHEAVEN_FARM_MONITOR_PID" ] && kill -0 "$ONIONHEAVEN_FARM_MONITOR_PID" 2>/dev/null; then
        kill "$ONIONHEAVEN_FARM_MONITOR_PID" 2>/dev/null || true
        wait "$ONIONHEAVEN_FARM_MONITOR_PID" 2>/dev/null || true
        ONIONHEAVEN_FARM_MONITOR_PID=""
    fi

    # Stop all farm containers (catches any scaled-up containers too)
    for container in $(docker ps -a --format '{{.Names}}' 2>/dev/null | grep -E '^onionheaven-(poll|takeover)-[0-9]+$'); do
        docker stop "$container" >> "$LOG_FILE" 2>&1 || true
        docker rm "$container" >> "$LOG_FILE" 2>&1 || true
        log "OnionHeaven farm: stopped $container"
    done
}

# Log file
LOG_FILE="$DATA_DIR/onionpress.log"

# Function to log messages
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

# Function to check if a command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Check if WordPress core is installed (setup wizard completed)
wp_is_installed() {
    docker exec onionpress-wordpress wp core is-installed --allow-root >/dev/null 2>&1
}

# Function to generate and load database passwords
setup_db_passwords() {
    local secrets_file="$DATA_DIR/secrets"

    # Create secrets file if it doesn't exist
    if [ ! -f "$secrets_file" ]; then
        log "Generating random database passwords..."

        # Generate random 32-character passwords using /dev/urandom
        # Use only alphanumeric chars to avoid shell quoting issues when sourcing
        local wordpress_pass=$(LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 32)
        local root_pass=$(LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 32)

        # Write passwords to secrets file with restricted permissions
        # Values are single-quoted to prevent shell interpretation on source
        touch "$secrets_file"
        chmod 600 "$secrets_file"

        cat > "$secrets_file" <<EOF
# Database passwords - generated on $(date)
# DO NOT SHARE THESE PASSWORDS
WORDPRESS_DB_PASSWORD='$wordpress_pass'
MYSQL_PASSWORD='$wordpress_pass'
MYSQL_ROOT_PASSWORD='$root_pass'
EOF

        log "Database passwords generated and saved to $secrets_file"
    fi

    # Load passwords from secrets file
    if [ -f "$secrets_file" ]; then
        source "$secrets_file"
        export WORDPRESS_DB_PASSWORD
        export MYSQL_PASSWORD
        export MYSQL_ROOT_PASSWORD
    else
        log "ERROR: Secrets file not found at $secrets_file"
        exit 1
    fi
}

# Function to detect container runtime
detect_container_runtime() {
    # Use bundled Colima
    if command_exists colima; then
        if [ -f "$COLIMA_HOME/.initialized" ]; then
            if "$BIN_DIR/colima" status >/dev/null 2>&1; then
                # Check if configured VM memory differs from running VM
                _cfg_mem=1
                if [ -f "$DATA_DIR/config" ]; then
                    _tmp_mem=$(grep "^VM_MEMORY=" "$DATA_DIR/config" | cut -d= -f2)
                    [ -n "$_tmp_mem" ] && _cfg_mem="$_tmp_mem"
                fi
                # Get actual VM memory in GB (MemTotal is in kB)
                _vm_mem_kb=$(docker exec onionpress-tor awk '/MemTotal/{print $2}' /proc/meminfo 2>/dev/null | tr -d ' \n\r')
                _vm_mem_kb="${_vm_mem_kb:-0}"
                _vm_mem_gb=$(( (_vm_mem_kb + 524288) / 1048576 ))  # round to nearest GB
                # Read configured CPU count
                _cfg_cpu=2
                if [ -f "$DATA_DIR/config" ]; then
                    _tmp_cpu=$(grep "^VM_CPU=" "$DATA_DIR/config" | cut -d= -f2)
                    [ -n "$_tmp_cpu" ] && _cfg_cpu="$_tmp_cpu"
                fi
                # Get actual VM CPU count
                _vm_cpus=$(docker exec onionpress-tor nproc 2>/dev/null | tr -d ' \n\r')
                _vm_cpus="${_vm_cpus:-0}"

                _need_restart=false
                if [ "$_cfg_mem" -gt 0 ] 2>/dev/null && [ "$_vm_mem_gb" -gt 0 ] 2>/dev/null && [ "$_cfg_mem" -ne "$_vm_mem_gb" ]; then
                    log "VM memory mismatch: config=${_cfg_mem}GB, running=${_vm_mem_gb}GB"
                    _need_restart=true
                fi
                if [ "$_cfg_cpu" -gt 0 ] 2>/dev/null && [ "$_vm_cpus" -gt 0 ] 2>/dev/null && [ "$_cfg_cpu" -ne "$_vm_cpus" ]; then
                    log "VM CPU mismatch: config=${_cfg_cpu}, running=${_vm_cpus}"
                    _need_restart=true
                fi
                if [ "$_need_restart" = true ]; then
                    log "Restarting VM with ${_cfg_cpu} CPUs, ${_cfg_mem}GB RAM..."
                    cd "$DOCKER_DIR"
                    docker compose down >> "$LOG_FILE" 2>&1 || true
                    "$BIN_DIR/colima" stop >> "$LOG_FILE" 2>&1
                    "$BIN_DIR/colima" start \
                        --mount "$DATA_DIR/shared:w" \
                        --cpu "$_cfg_cpu" \
                        --memory "$_cfg_mem" \
                        >> "$LOG_FILE" 2>&1
                    if [ $? -eq 0 ]; then
                        log "VM restarted with ${_cfg_cpu} CPUs, ${_cfg_mem}GB"
                    else
                        log "WARNING: VM restart failed"
                    fi
                fi
                echo "colima-bundled"
                return 0
            else
                # Start Colima if stopped
                log "Starting bundled Colima..."

                # Read VM memory/CPU from config so restarts honour changes
                _restart_mem=1
                _restart_cpu=2
                if [ -f "$DATA_DIR/config" ]; then
                    _cfg_mem=$(grep "^VM_MEMORY=" "$DATA_DIR/config" | cut -d= -f2)
                    [ -n "$_cfg_mem" ] && _restart_mem="$_cfg_mem"
                    _cfg_cpu=$(grep "^VM_CPU=" "$DATA_DIR/config" | cut -d= -f2)
                    [ -n "$_cfg_cpu" ] && _restart_cpu="$_cfg_cpu"
                fi

                "$BIN_DIR/colima" start \
                    --mount "$DATA_DIR/shared:w" \
                    --cpu "$_restart_cpu" \
                    --memory "$_restart_mem" \
                    >> "$LOG_FILE" 2>&1
                if [ $? -eq 0 ]; then
                    echo "colima-bundled"
                    return 0
                fi
            fi
        fi
    fi

    # Fallback to system Docker (for development)
    if command_exists docker && docker info >/dev/null 2>&1; then
        echo "docker-system"
        return 0
    fi

    return 1
}

# Function to generate custom onion address with prefix
generate_vanity_address() {
    local prefix="${1:-op2}"
    # Use shared directory so Docker/Colima can access it
    local output_dir="$DATA_DIR/shared/vanity-keys"

    log "Generating custom onion address with prefix '$prefix'..." >&2

    # Create output directory
    mkdir -p "$output_dir"

    # Check if mkp224o is available
    if [ ! -f "$BIN_DIR/mkp224o" ]; then
        log "WARNING: mkp224o not found, using random address" >&2
        return 1
    fi

    # Generate address with prefix (single threaded for consistency)
    cd "$output_dir"
    "$BIN_DIR/mkp224o" -d . -n 1 -t 4 "$prefix" >> "$LOG_FILE" 2>&1

    # Find generated directory
    VANITY_DIR=$(find "$output_dir" -type d -name "${prefix}*" | head -1)

    if [ -z "$VANITY_DIR" ]; then
        log "ERROR: Failed to generate custom address" >&2
        return 1
    fi

    VANITY_ADDRESS=$(basename "$VANITY_DIR")
    log "Generated custom address: $VANITY_ADDRESS" >&2

    # Convert mkp224o C Tor format to Arti OpenSSH format
    if [ -f "$VANITY_DIR/hs_ed25519_secret_key" ] && [ -f "$VANITY_DIR/hs_ed25519_public_key" ]; then
        bundled_python -c "
import base64, os, struct, sys

secret_path = sys.argv[1]
public_path = sys.argv[2]
output_path = sys.argv[3]

# Read C Tor format: 32-byte header + key
with open(secret_path, 'rb') as f:
    secret_data = f.read()
private_key = secret_data[32:]  # 64 bytes

with open(public_path, 'rb') as f:
    public_data = f.read()
public_key = public_data[32:]  # 32 bytes

KEY_TYPE = b'ed25519-expanded@spec.torproject.org'
MAGIC = b'openssh-key-v1\x00'

def pack(data):
    return struct.pack('>I', len(data)) + data

pub_blob = pack(KEY_TYPE) + pack(public_key)

check = struct.pack('>I', int.from_bytes(os.urandom(4), 'big'))
priv_blob = (
    check + check +
    pack(KEY_TYPE) +
    pack(public_key) +
    pack(private_key) +
    pack(b'')
)
pad_len = (8 - len(priv_blob) % 8) % 8
priv_blob += bytes(range(1, pad_len + 1))

binary = (
    MAGIC +
    pack(b'none') +
    pack(b'none') +
    pack(b'') +
    struct.pack('>I', 1) +
    pack(pub_blob) +
    pack(priv_blob)
)

b64 = base64.b64encode(binary).decode('ascii')
lines = [b64[i:i+70] for i in range(0, len(b64), 70)]
pem = '-----BEGIN OPENSSH PRIVATE KEY-----\n'
pem += '\n'.join(lines) + '\n'
pem += '-----END OPENSSH PRIVATE KEY-----\n'

with open(output_path, 'wb') as f:
    f.write(pem.encode('utf-8'))
os.chmod(output_path, 0o600)
" "$VANITY_DIR/hs_ed25519_secret_key" "$VANITY_DIR/hs_ed25519_public_key" "$VANITY_DIR/ks_hs_id.ed25519_expanded_private" >> "$LOG_FILE" 2>&1

        if [ $? -eq 0 ]; then
            # Remove old C Tor format files
            rm -f "$VANITY_DIR/hs_ed25519_secret_key" "$VANITY_DIR/hs_ed25519_public_key"
            log "Converted vanity key to Arti OpenSSH format" >&2
        else
            log "ERROR: Failed to convert vanity key to Arti format" >&2
            return 1
        fi
    fi

    # Return the directory path (only thing on stdout)
    echo "$VANITY_DIR"
    return 0
}

# Function to import a pre-generated onion service key
import_key() {
    local key_b32="$1"

    # Ensure data directory exists (import-key may run before first launch)
    mkdir -p "$DATA_DIR"

    # Show help if no argument or --help
    if [ -z "$key_b32" ] || [ "$key_b32" = "--help" ] || [ "$key_b32" = "-h" ]; then
        cat <<HELPEOF
Usage: onionpress import-key <base32-secret-key>

Import a pre-generated ed25519 key for your onion service.

The base32 key should encode the 64-byte expanded ed25519 secret key.
OnionPress will derive the .onion address automatically.

HOW TO GET THE KEY FROM mkp224o OUTPUT:

  OnionPress stores vanity keys in ~/.onionpress/shared/vanity-keys/.
  Each address has its own directory containing hs_ed25519_secret_key.
  Encode that file to base32:

    PYTHONHOME=$_BUNDLED_PYTHONHOME $_BUNDLED_PYTHON_BIN -c "import base64; print(base64.b32encode(open('\$HOME/.onionpress/shared/vanity-keys/<address>.onion/hs_ed25519_secret_key','rb').read()).decode())"

  If you ran mkp224o yourself, substitute the path to your output directory.

  OnionPress accepts both the full file (96 bytes with header) and the
  64-byte key alone (read()[32:]).

EXAMPLE:

  KEY=\$(PYTHONHOME=$_BUNDLED_PYTHONHOME $_BUNDLED_PYTHON_BIN -c "import base64; print(base64.b32encode(open('\$HOME/.onionpress/shared/vanity-keys/<address>.onion/hs_ed25519_secret_key','rb').read()).decode())")
  ./onionpress import-key "\$KEY"

WHAT THIS COMMAND DOES:

  1. Decodes the base32 key and validates it is exactly 64 bytes
  2. Derives the .onion address from the public key portion
  3. Writes key files to ~/.onionpress/shared/vanity-keys/<address>/
     - ks_hs_id.ed25519_expanded_private  (OpenSSH PEM format for Arti)
     - hostname                           (the .onion address)
  4. On next start, OnionPress will use this key

NOTE: If an onion address already exists, you will be prompted to
confirm the replacement. OnionPress will handle stopping and
removing the old keys automatically.

HELPEOF
        return 0
    fi

    # Decode base32, validate length, derive public key and address — all in one call
    # The public key must be derived via ed25519 scalar multiplication (not a simple slice)
    local result
    result=$(bundled_python -c "
import base64, hashlib, sys, binascii

key_b32 = sys.argv[1]

# Decode base32
try:
    key_bytes = base64.b32decode(key_b32, casefold=True)
except Exception as e:
    print(f'ERROR: Invalid base32 encoding: {e}', file=sys.stderr)
    sys.exit(1)

# Accept 96 bytes (full file with 32-byte header) or 64 bytes (key only)
if len(key_bytes) == 96 and key_bytes[:29] == b'== ed25519v1-secret: type0 ==':
    key_bytes = key_bytes[32:]
elif len(key_bytes) != 64:
    print(f'ERROR: Key must be exactly 64 bytes (or 96 with header), got {len(key_bytes)}', file=sys.stderr)
    sys.exit(1)

# Derive public key from expanded secret key via ed25519 scalar multiplication
p = 2**255 - 19
def inv(x): return pow(x, p-2, p)
d = -121665 * inv(121666) % p

def recover_x(y, sign):
    x2 = (y*y-1) * inv(d*y*y+1) % p
    x = pow(x2, (p+3)//8, p)
    if (x*x - x2) % p != 0:
        x = x * pow(2, (p-1)//4, p) % p
    if x % 2 != sign: x = p - x
    return x

By = 4 * inv(5) % p
Bx = recover_x(By, 0)
B = (Bx, By, 1, Bx*By % p)

def point_add(P, Q):
    x1,y1,z1,t1 = P; x2,y2,z2,t2 = Q
    a=(y1-x1)*(y2-x2)%p; b=(y1+x1)*(y2+x2)%p
    c=2*t1*t2*d%p; dd=2*z1*z2%p
    e=b-a; f=dd-c; g=dd+c; h=b+a
    return (e*f%p, g*h%p, f*g%p, e*h%p)

def scalar_mult(s, P):
    Q = (0, 1, 1, 0)
    while s > 0:
        if s & 1: Q = point_add(Q, P)
        P = point_add(P, P)
        s >>= 1
    return Q

def encode_point(P):
    x,y,z,_ = P; zi = inv(z)
    x,y = x*zi%p, y*zi%p
    r = bytearray(y.to_bytes(32,'little'))
    r[31] ^= (x&1) << 7
    return bytes(r)

scalar = int.from_bytes(key_bytes[:32], 'little')
pubkey = encode_point(scalar_mult(scalar, B))

# Derive .onion address (v3 spec)
checksum = hashlib.sha3_256(b'.onion checksum' + pubkey + b'\x03').digest()[:2]
address = base64.b32encode(pubkey + checksum + b'\x03').decode().lower() + '.onion'

# Output: address on line 1, hex key on line 2, hex pubkey on line 3
print(address)
print(binascii.hexlify(key_bytes).decode())
print(binascii.hexlify(pubkey).decode())
" "$key_b32" 2>&1)

    if [ $? -ne 0 ]; then
        echo "$result" >&2
        return 1
    fi

    # Parse python output
    local address hex_key hex_pubkey
    address=$(echo "$result" | sed -n '1p')
    hex_key=$(echo "$result" | sed -n '2p')
    hex_pubkey=$(echo "$result" | sed -n '3p')

    if [ -z "$address" ] || [ -z "$hex_key" ] || [ -z "$hex_pubkey" ]; then
        echo "ERROR: Failed to derive address from key" >&2
        return 1
    fi

    # Check if this is the same key already installed
    local current_addr
    current_addr=$(find "$DATA_DIR/shared/vanity-keys" -name hostname -exec cat {} \; 2>/dev/null | head -1)
    if [ "$current_addr" = "$address" ]; then
        echo "Key already installed for: $address"
        echo "Nothing to do."
        return 0
    fi

    # Check if arti-state volume already exists (need to replace old key)
    if docker volume ls --format '{{.Name}}' 2>/dev/null | grep -q '^onionpress-arti-state$'; then
        echo "An onion address key already exists."
        echo ""
        if [ -n "$current_addr" ]; then
            echo "Current address: $current_addr"
            echo ""
        fi
        echo "Importing a new key will REPLACE your current onion address."
        echo "Your old address will stop working permanently."
        echo ""
        printf "Continue? [y/N] "
        read -r confirm
        if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
            echo "Cancelled."
            return 1
        fi

        # Stop OnionPress if running
        echo "Stopping OnionPress..."
        stop_containers 2>/dev/null
        # Remove old arti-state volume (must verify it's actually gone)
        echo "Removing old arti-state volume..."
        docker volume rm onionpress-arti-state >> "$LOG_FILE" 2>&1 || true
        if docker volume ls --format '{{.Name}}' 2>/dev/null | grep -q '^onionpress-arti-state$'; then
            echo "Volume still in use — force-removing containers..."
            docker rm -f $(docker ps -aq --filter volume=onionpress-arti-state) >> "$LOG_FILE" 2>&1 || true
            docker volume rm onionpress-arti-state >> "$LOG_FILE" 2>&1 || true
            if docker volume ls --format '{{.Name}}' 2>/dev/null | grep -q '^onionpress-arti-state$'; then
                echo "ERROR: Could not remove old arti-state volume. Is another Docker client using it?" >&2
                return 1
            fi
        fi
        # Also remove old tor-keys volume if it exists (migration leftover)
        docker volume rm onionpress-tor-keys >> "$LOG_FILE" 2>&1 || true
        # Remove old vanity-keys directory
        rm -rf "$DATA_DIR/shared/vanity-keys/"
        echo "Old keys removed."
    elif [ -d "$DATA_DIR/shared/vanity-keys" ]; then
        # Docker not running but old vanity-keys exist — clean them up
        rm -rf "$DATA_DIR/shared/vanity-keys/"
    fi

    # Mark that a key was imported so next startup removes the old arti-state volume
    # (needed when Docker isn't running and we can't remove the volume now)
    touch "$DATA_DIR/.import-key-pending"

    # Create output directory
    local output_dir="$DATA_DIR/shared/vanity-keys/$address"
    mkdir -p "$output_dir"

    # Write OpenSSH PEM key file for Arti (same format as key_manager.build_openssh_key)
    bundled_python -c "
import base64, binascii, os, struct, sys

hex_key = sys.argv[1]
hex_pubkey = sys.argv[2]
output_path = sys.argv[3]

private_key = binascii.unhexlify(hex_key)   # 64 bytes
public_key = binascii.unhexlify(hex_pubkey)  # 32 bytes

KEY_TYPE = b'ed25519-expanded@spec.torproject.org'
MAGIC = b'openssh-key-v1\x00'

def pack(data):
    return struct.pack('>I', len(data)) + data

# Public key blob
pub_blob = pack(KEY_TYPE) + pack(public_key)

# Private key blob
check = struct.pack('>I', int.from_bytes(os.urandom(4), 'big'))
priv_blob = (
    check + check +
    pack(KEY_TYPE) +
    pack(public_key) +
    pack(private_key) +
    pack(b'')  # empty comment
)
pad_len = (8 - len(priv_blob) % 8) % 8
priv_blob += bytes(range(1, pad_len + 1))

binary = (
    MAGIC +
    pack(b'none') +
    pack(b'none') +
    pack(b'') +
    struct.pack('>I', 1) +
    pack(pub_blob) +
    pack(priv_blob)
)

b64 = base64.b64encode(binary).decode('ascii')
lines = [b64[i:i+70] for i in range(0, len(b64), 70)]
pem = '-----BEGIN OPENSSH PRIVATE KEY-----\n'
pem += '\n'.join(lines) + '\n'
pem += '-----END OPENSSH PRIVATE KEY-----\n'

with open(output_path, 'wb') as f:
    f.write(pem.encode('utf-8'))
os.chmod(output_path, 0o600)
" "$hex_key" "$hex_pubkey" "$output_dir/ks_hs_id.ed25519_expanded_private"

    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to write OpenSSH key file" >&2
        return 1
    fi

    # Write hostname file
    echo "$address" > "$output_dir/hostname"
    chmod 644 "$output_dir/hostname"

    # Update ADDRESS_PREFIX in config to match the imported address
    # so the startup prefix check doesn't flag a mismatch
    # Use current prefix length if set, otherwise default to first 3 chars
    local current_prefix=""
    if [ -f "$DATA_DIR/config" ]; then
        current_prefix=$(grep "^ADDRESS_PREFIX=" "$DATA_DIR/config" | cut -d= -f2)
    fi
    local prefix_len=${#current_prefix}
    if [ "$prefix_len" -lt 2 ]; then
        prefix_len=3
    fi
    local addr_prefix=$(echo "$address" | cut -c1-$prefix_len)
    if [ -f "$DATA_DIR/config" ] && grep -q "^ADDRESS_PREFIX=" "$DATA_DIR/config"; then
        sed -i '' "s/^ADDRESS_PREFIX=.*/ADDRESS_PREFIX=$addr_prefix/" "$DATA_DIR/config"
    else
        echo "ADDRESS_PREFIX=$addr_prefix" >> "$DATA_DIR/config"
    fi
    log "Updated ADDRESS_PREFIX to '$addr_prefix' to match imported key"

    log "Imported key for address: $address"
    echo "Imported key for: $address"
    echo "Key files written to: $output_dir"
    echo ""
    echo "Launch OnionPress to use this address."
    return 0
}

# Function to install and activate Internet Archive Wayback Machine Link Fixer plugin
install_ia_plugin() {
    # Check if plugin installation is enabled in config
    local install_plugin="yes"
    if [ -f "$DATA_DIR/config" ]; then
        local config_value=$(grep "^INSTALL_IA_PLUGIN=" "$DATA_DIR/config" | cut -d= -f2)
        if [ ! -z "$config_value" ]; then
            install_plugin="$config_value"
        fi
    fi

    if [ "$install_plugin" != "yes" ]; then
        log "Internet Archive plugin installation disabled in config"
        return 0
    fi

    # Check if installation scripts exist
    if [ ! -d "$SCRIPTS_DIR" ] || [ ! -f "$SCRIPTS_DIR/install_plugin.sh" ]; then
        log "Plugin installation scripts not available, skipping"
        return 0
    fi

    log "Checking Internet Archive Wayback Machine Link Fixer plugin..."

    cd "$DOCKER_DIR"

    # Check if plugin is already installed
    if docker compose exec -T wordpress test -f /var/www/html/wp-content/plugins/internet-archive-wayback-machine-link-fixer/internet-archive-wayback-machine-link-fixer.php 2>/dev/null; then
        # Plugin is installed, try to activate if WordPress is configured
        log "Internet Archive plugin already installed, checking activation status..."
        if "$SCRIPTS_DIR/activate_plugin.sh" "onionpress-wordpress" \
            "internet-archive-wayback-machine-link-fixer/internet-archive-wayback-machine-link-fixer.php" >>"$LOG_FILE" 2>&1; then
            log "✓ Internet Archive Wayback Machine Link Fixer plugin is active"
        else
            log "Plugin will auto-activate after WordPress setup"
        fi
        return 0
    fi

    log "Installing Internet Archive Wayback Machine Link Fixer plugin..."

    # Create temp directory for plugin download
    local temp_dir=$(mktemp -d)

    # Download and verify plugin using bash script with checksum verification
    if "$SCRIPTS_DIR/install_plugin.sh" "internet-archive-wayback-machine-link-fixer" "$temp_dir" >>"$LOG_FILE" 2>&1; then
        # Copy plugin to WordPress container
        if docker cp "$temp_dir/internet-archive-wayback-machine-link-fixer" onionpress-wordpress:/var/www/html/wp-content/plugins/ 2>>"$LOG_FILE" && \
            cd "$DOCKER_DIR" && \
            docker compose exec -T wordpress chown -R www-data:www-data /var/www/html/wp-content/plugins/internet-archive-wayback-machine-link-fixer 2>>"$LOG_FILE"; then
            log "✓ Internet Archive Wayback Machine Link Fixer plugin installed with verified checksum!"

            # Try to activate immediately if WordPress is configured
            if "$SCRIPTS_DIR/activate_plugin.sh" "onionpress-wordpress" \
                "internet-archive-wayback-machine-link-fixer/internet-archive-wayback-machine-link-fixer.php" >>"$LOG_FILE" 2>&1; then
                log "✓ Plugin automatically activated!"
            else
                log "Plugin will auto-activate after WordPress setup"
            fi
        else
            log "Failed to copy plugin to container"
        fi
    else
        log "Failed to download and verify plugin - check log for details"
    fi

    # Clean up
    rm -rf "$temp_dir"

    return 0
}

# Function to configure IA Wayback Machine Link Fixer plugin options via WP-CLI
configure_ia_plugin() {
    # Check if plugin installation is enabled in config
    local install_plugin="yes"
    if [ -f "$DATA_DIR/config" ]; then
        local config_value=$(grep "^INSTALL_IA_PLUGIN=" "$DATA_DIR/config" | cut -d= -f2)
        if [ ! -z "$config_value" ]; then
            install_plugin="$config_value"
        fi
    fi

    if [ "$install_plugin" != "yes" ]; then
        return 0
    fi

    # Skip if WordPress is not installed yet
    if ! wp_is_installed; then
        return 0
    fi

    # Skip if plugin is not installed
    if ! docker exec onionpress-wordpress test -f /var/www/html/wp-content/plugins/internet-archive-wayback-machine-link-fixer/internet-archive-wayback-machine-link-fixer.php 2>/dev/null; then
        return 0
    fi

    # Check if already configured (idempotent — don't overwrite user customizations)
    local wizard_done
    wizard_done=$(docker exec onionpress-wordpress wp option get iawmlf_setup_wizard_completed --allow-root 2>/dev/null || echo "")
    if [ "$wizard_done" = "1" ]; then
        log "✓ Internet Archive plugin already configured"
        return 0
    fi

    log "Configuring Internet Archive Wayback Machine Link Fixer plugin..."

    # Enable link fixer (scans outbound links, replaces broken ones with archived versions)
    docker exec onionpress-wordpress wp option update iawmlf_process_links 1 --allow-root >> "$LOG_FILE" 2>&1 \
        || log "WARNING: Failed to set iawmlf_process_links"
    docker exec onionpress-wordpress wp option update iawmlf_fixer_option replace_link --allow-root >> "$LOG_FILE" 2>&1 \
        || log "WARNING: Failed to set iawmlf_fixer_option"
    docker exec onionpress-wordpress wp option update iawmlf_scan_existing_posts 1 --allow-root >> "$LOG_FILE" 2>&1 \
        || log "WARNING: Failed to set iawmlf_scan_existing_posts"

    # Mark setup wizard complete (prevents wizard UI from showing)
    docker exec onionpress-wordpress wp option update iawmlf_setup_wizard_completed 1 --allow-root >> "$LOG_FILE" 2>&1 \
        || log "WARNING: Failed to set iawmlf_setup_wizard_completed"

    # Do NOT enable the plugin's own auto-archive — our mu-plugin handles it
    # with proper .onion URLs and Tor routing

    log "✓ Internet Archive plugin configured (link fixer enabled, wizard completed)"
    return 0
}

# Function to fix permissions for onionpress persistent data directory
fix_onionpress_permissions() {
    log "Fixing permissions for onionpress persistent data directory..."

    cd "$DOCKER_DIR"

    # Ensure the directory exists and is owned by www-data
    # Use 750 (rwxr-x---) to prevent other users from reading the directory
    # Skip OnionHeaven/ subdirectory — onionheaven-server.py runs as root and manages its own permissions
    if docker compose exec -T wordpress sh -c '
        chmod 750 /var/lib/onionpress
        find /var/lib/onionpress -maxdepth 0 -exec chown www-data:www-data {} +
        find /var/lib/onionpress -mindepth 1 -maxdepth 1 ! -name onionheaven -exec chown -R www-data:www-data {} +
    ' 2>>"$LOG_FILE"; then
        log "✓ Onionpress data directory permissions fixed"
        return 0
    else
        log "WARNING: Could not fix onionpress data directory permissions"
        return 1
    fi
}

# Function to initialize container runtime
install_docker() {
    log "Container runtime initialization required"

    # Read VM memory from config (default: 1 GB)
    VM_MEMORY=1
    VM_CPU=2
    if [ -f "$DATA_DIR/config" ]; then
        config_mem=$(grep "^VM_MEMORY=" "$DATA_DIR/config" | cut -d= -f2)
        if [ ! -z "$config_mem" ]; then
            VM_MEMORY="$config_mem"
        fi
        config_cpu=$(grep "^VM_CPU=" "$DATA_DIR/config" | cut -d= -f2)
        if [ ! -z "$config_cpu" ]; then
            VM_CPU="$config_cpu"
        fi
    fi

    # Pre-check: if onionheaven key is imported, ensure at least 5GB + 3/4 host CPUs (preserve higher values)
    local onionheaven_address="oheavenfhbohpdjijmxo3xgvvuo6eleyhhorbompoycle6x5eajlp7qd.onion"
    if [ -d "$DATA_DIR/shared/vanity-keys/$onionheaven_address" ]; then
        if [ "$VM_MEMORY" -lt 8 ]; then
            log "OnionHeaven key detected — starting VM with 8GB (was ${VM_MEMORY}GB)"
            VM_MEMORY=8
        fi
        local host_cores
        host_cores=$(sysctl -n hw.ncpu 2>/dev/null || echo 4)
        local oh_cpus=$(( host_cores * 3 / 4 ))
        [ "$oh_cpus" -lt 2 ] && oh_cpus=2
        if [ "$VM_CPU" -lt "$oh_cpus" ]; then
            log "OnionHeaven key detected — starting VM with ${oh_cpus} CPUs (was ${VM_CPU}, host has ${host_cores})"
            VM_CPU="$oh_cpus"
        fi
    fi

    # Should not happen if launcher worked, but handle it
    if [ "$VM_ARCH" = "aarch64" ]; then
        # Apple Silicon: use VZ backend (Virtualization.framework)
        "$BIN_DIR/colima" start \
            --vm-type vz \
            --mount-type virtiofs \
            --mount "$DATA_DIR/shared:w" \
            --cpu "$VM_CPU" \
            --memory "$VM_MEMORY" \
            --arch "$VM_ARCH" \
            --vz-rosetta=false \
            >> "$LOG_FILE" 2>&1
    else
        # Intel: use QEMU backend
        "$BIN_DIR/colima" start \
            --vm-type qemu \
            --mount-type sshfs \
            --mount "$DATA_DIR/shared:w" \
            --cpu "$VM_CPU" \
            --memory "$VM_MEMORY" \
            --arch "$VM_ARCH" \
            >> "$LOG_FILE" 2>&1
    fi

    if [ $? -eq 0 ]; then
        touch "$COLIMA_HOME/.initialized"
        log "Container runtime initialized successfully"
        return 0
    else
        log "ERROR: Failed to initialize container runtime"
        echo "ERROR: Failed to initialize container runtime." >&2
        echo "Check the logs for details: $LOG_FILE" >&2
        echo "Or file an issue at: https://github.com/brewsterkahle/onionpress/issues" >&2
        exit 1
    fi
}

# Function to update Docker images if enabled
update_images() {
    # Check if auto-update is enabled in config
    local update_enabled="no"
    if [ -f "$DATA_DIR/config" ]; then
        local config_value=$(grep "^UPDATE_ON_LAUNCH=" "$DATA_DIR/config" | cut -d= -f2)
        if [ ! -z "$config_value" ]; then
            update_enabled="$config_value"
        fi
    fi

    if [ "$update_enabled" != "yes" ]; then
        return 0
    fi

    log "Checking for Docker image updates..."

    cd "$DOCKER_DIR"

    # Pull latest images (WordPress, MariaDB, Tor)
    local images=("ghcr.io/brewsterkahle/onionpress-tor:latest" "ghcr.io/brewsterkahle/onionpress-wordpress:latest" "mariadb:latest")
    local updated=false

    for image in "${images[@]}"; do
        log "Pulling $image..."
        if docker pull "$image" >> "$LOG_FILE" 2>&1; then
            log "✓ $image up to date"
            updated=true
        else
            log "WARNING: Failed to pull $image (continuing with cached version)"
        fi
    done

    if [ "$updated" = true ]; then
        log "✓ Image update check complete"
    fi

    return 0
}

# Function to ensure WordPress multisite is active (runs on every startup)
ensure_multisite() {
    # Skip if WordPress is not installed yet
    if ! wp_is_installed; then
        log "WordPress not installed yet — skipping multisite check"
        return 0
    fi

    cd "$DOCKER_DIR"

    # Check if multisite is already active
    if docker exec onionpress-wordpress wp core is-installed --network --allow-root >/dev/null 2>&1; then
        log "✓ WordPress multisite already active"
        return 0
    fi

    log "Converting single-site WordPress to multisite..."

    # Convert to multisite (subdirectory mode)
    # --url=http://localhost is required because WP_HOME uses $_SERVER['HTTP_HOST']
    # which is undefined in CLI context, causing WP to store "http:" as the domain
    if ! docker exec onionpress-wordpress wp core multisite-convert \
        --url=http://localhost --allow-root >> "$LOG_FILE" 2>&1; then
        log "WARNING: wp core multisite-convert failed (may already be multisite)"
    fi

    # Set multisite constants
    local constants=(
        "MULTISITE:true"
        "SUBDOMAIN_INSTALL:false"
        "DOMAIN_CURRENT_SITE:'localhost'"
        "PATH_CURRENT_SITE:'/'"
        "SITE_ID_CURRENT_SITE:1"
        "BLOG_ID_CURRENT_SITE:1"
        "SUNRISE:true"
    )

    for entry in "${constants[@]}"; do
        local name="${entry%%:*}"
        local value="${entry#*:}"
        docker exec onionpress-wordpress wp config set "$name" "$value" \
            --raw --type=constant --allow-root >> "$LOG_FILE" 2>&1
    done

    # Write .htaccess with multisite rewrite rules
    docker exec onionpress-wordpress bash -c 'cat > /var/www/html/.htaccess << "HTEOF"
# BEGIN WordPress Multisite
RewriteEngine On
RewriteBase /
RewriteRule ^index\.php$ - [L]

# add a trailing slash to /wp-admin
RewriteRule ^([_0-9a-zA-Z-]+/)?wp-admin$ $1wp-admin/ [R=301,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule ^([_0-9a-zA-Z-]+/)?(wp-(content|admin|includes).*) $2 [L]
RewriteRule ^([_0-9a-zA-Z-]+/)?(.*\.php)$ $2 [L]
RewriteRule . index.php [L]
# END WordPress Multisite
HTEOF
chown www-data:www-data /var/www/html/.htaccess' >> "$LOG_FILE" 2>&1

    log "✓ WordPress multisite conversion complete"
    return 0
}

