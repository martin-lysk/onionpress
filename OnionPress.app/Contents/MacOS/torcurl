#!/bin/bash
# torcurl — curl via OnionPress's Tor network
# Usage: torcurl [-l|--launch] [curl-options] <url>
#   -l, --launch  Launch OnionPress first if not running

# Resolve symlinks so this works from OnionPress.app/torcurl symlink
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
APP_DIR="$(dirname "$SCRIPT_DIR")"
DOCKER="$APP_DIR/Resources/bin/docker"
ONIONPRESS="$SCRIPT_DIR/onionpress"
# Clear any Docker env that could override our socket target
unset DOCKER_HOST DOCKER_CONTEXT
DOCKER_ARGS="--host unix://$HOME/.onionpress/colima/default/docker.sock"

# Check if Tor SOCKS proxy can route traffic
tor_ready() {
    "$DOCKER" $DOCKER_ARGS exec onionpress-wordpress \
        curl -s --max-time 5 --socks5-hostname onionpress-tor:9050 \
        https://example.com -o /dev/null -w '%{http_code}' 2>/dev/null | grep -q 200
}

# Parse our flags, pass everything else to curl
FORCE_START=false
ARGS=()
for arg in "$@"; do
    if [ "$arg" = "-l" ] || [ "$arg" = "--launch" ]; then
        FORCE_START=true
    else
        ARGS+=("$arg")
    fi
done

if [ ${#ARGS[@]} -eq 0 ]; then
    echo "Usage: torcurl [-l|--launch] [curl-options] <url>"
    echo "  -l, --launch  Launch OnionPress if not running"
    exit 1
fi

# Check if WordPress container is running
if ! "$DOCKER" $DOCKER_ARGS inspect --format='{{.State.Running}}' onionpress-wordpress 2>/dev/null | grep -q true; then
    if [ "$FORCE_START" = true ]; then
        echo "OnionPress not running, launching..." >&2
        "$ONIONPRESS" launch
        # Wait for WordPress container to come up
        echo "Waiting for OnionPress to be ready..." >&2
        for i in $(seq 1 120); do
            if "$DOCKER" $DOCKER_ARGS inspect --format='{{.State.Running}}' onionpress-wordpress 2>/dev/null | grep -q true; then
                break
            fi
            sleep 2
        done
        if ! "$DOCKER" $DOCKER_ARGS inspect --format='{{.State.Running}}' onionpress-wordpress 2>/dev/null | grep -q true; then
            echo "Timed out waiting for OnionPress to start." >&2
            exit 1
        fi
    else
        echo "OnionPress is not running. Start it first, or use -l to auto-launch." >&2
        exit 1
    fi
fi

# Run the request
"$DOCKER" $DOCKER_ARGS exec onionpress-wordpress curl -s --max-time 30 --socks5-hostname onionpress-tor:9050 "${ARGS[@]}"
rc=$?

# If curl failed with SOCKS error (97), Tor may still be building circuits.
# Wait for Tor to be ready and retry.
if [ $rc -eq 97 ]; then
    echo "Tor not ready yet, waiting for circuits..." >&2
    for i in $(seq 1 30); do
        if tor_ready; then
            "$DOCKER" $DOCKER_ARGS exec onionpress-wordpress curl -s --max-time 30 --socks5-hostname onionpress-tor:9050 "${ARGS[@]}"
            exit $?
        fi
        sleep 2
    done
    echo "Tor is not ready. Try again in a moment." >&2
    exit 1
fi

exit $rc
